<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Busca+</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link rel="stylesheet" href="/css/search.css">
</head>
<body class="<%= !hasQuery ? 'home-landing' : '' %>">
  <% if (!hasQuery) { %>
    <div class="header">
      <a href="/" class="logo">Busca<span>+</span></a>
      <div class="nav-links">
        <button type="button" class="nav-location-btn js-open-location" title="Alterar localização">
          <span class="material-icons">location_on</span>
          <span class="nav-location-label"><%= city ? city : (state ? state : 'Localização') %></span>
        </button>
        <span class="material-icons">apps</span>
        <span class="material-icons">notifications</span>
        <div class="user-avatar">B</div>
      </div>
    </div>
    <div class="empty-state">
      <div class="logo-large logo">Busca<span>+</span></div>
      <form class="initial-search" action="/" method="GET">
        <div class="search-header">
          <span class="material-icons">search</span>
          <input type="text" name="q" class="form-control" placeholder="Pesquisar no Busca+" autofocus>
          <button type="button" class="clear-btn" aria-label="Limpar pesquisa">
            <span class="material-icons">close</span>
          </button>
        </div>
        <div class="initial-buttons">
          <button type="submit">Pesquisa Busca+</button>
          <button type="button">Estou com sorte</button>
        </div>
      </form>
    </div>
  <% } else { %>
    <div class="header">
      <a href="/" class="logo">Busca<span>+</span></a>
      <form class="search-header" action="/" method="GET">
        <span class="material-icons">search</span>
        <input type="text" name="q" value="<%= query %>" autocomplete="off">
        <input type="hidden" name="tab" value="<%= tab %>">
        <% if (source) { %>
          <input type="hidden" name="source" value="<%= source %>">
        <% } %>
        <% if (state) { %>
          <input type="hidden" name="state" value="<%= state %>">
        <% } %>
        <% if (city) { %>
          <input type="hidden" name="city" value="<%= city %>">
        <% } %>
        <button type="button" class="clear-btn" aria-label="Limpar pesquisa">
          <span class="material-icons">close</span>
        </button>
      </form>
      <div class="nav-links">
        <button type="button" class="nav-location-btn js-open-location" title="Alterar localização">
          <span class="material-icons">location_on</span>
          <span class="nav-location-label"><%= city ? city : (state ? state : 'Localização') %></span>
        </button>
        <span class="material-icons">apps</span>
        <span class="material-icons">notifications</span>
        <div class="user-avatar">B</div>
      </div>
    </div>

    <nav class="tabs" aria-label="Filtros da pesquisa">
      <% tabs.forEach((item) => { %>
        <a
          href="<%= item.href %>"
          class="tab <%= item.active ? 'active' : '' %> <%= item.supported ? '' : 'tab-disabled' %>"
          <%= item.supported ? '' : 'aria-disabled="true"' %>
        >
          <span class="material-icons"><%= item.icon %></span>
          <%= item.label %>
        </a>
      <% }) %>
    </nav>

    <%
      const aiReportEnabled = !aiFeatures || (aiFeatures.enabled !== false && aiFeatures.features && aiFeatures.features.searchReport !== false);
    %>
    <% if (hasQuery && results && results.length > 0 && aiReportEnabled) { %>
    <div class="ai-report-section" id="aiReportSection" data-query="<%= query %>">
      <div class="ai-report-loading" id="aiReportLoading">
        <div class="ai-report-spinner"></div>
        <div class="ai-report-text">
          <span class="ai-report-label">Gerando relatorio com IA</span>
          <span class="ai-report-sublabel">Analisando os <%= totalHits %> resultados...</span>
        </div>
      </div>
      <div class="ai-report-content" id="aiReportContent" hidden>
        <div class="ai-report-header">
          <div class="ai-report-icon">
            <span class="material-icons">auto_awesome</span>
          </div>
          <div class="ai-report-title">
            <h3>Resumo da Busca</h3>
            <span class="ai-report-meta" id="aiReportMeta"></span>
          </div>
          <button type="button" class="ai-report-close" id="aiReportClose" aria-label="Fechar">
            <span class="material-icons">close</span>
          </button>
        </div>
        <div class="ai-report-body" id="aiReportBody"></div>
      </div>
    </div>
    <% } %>

    <div class="main-content">
      <% if (tab === 'images') { %>
        <div class="results-column results-column-full">
          <div class="stats-line"><%= statsLabel %></div>
          <% if (imageCards && imageCards.length > 0) { %>
            <div class="images-grid">
              <% imageCards.forEach((image) => { %>
                <button
                  type="button"
                  class="image-card"
                  data-image-src="<%= image.thumbnailPath %>"
                  data-image-title="<%= image.title %>"
                  data-image-url="<%= image.url %>"
                  data-image-domain="<%= image.domain %>"
                >
                  <img src="<%= image.thumbnailPath %>" alt="<%= image.alt %>" loading="lazy">
                  <div class="image-info">
                    <div><%= image.title.substring(0, 50) %></div>
                    <div class="image-domain"><%= image.domain %></div>
                  </div>
                </button>
              <% }) %>
            </div>
          <% } else { %>
            <div class="empty-state compact-empty-state"><h3>Nenhuma imagem encontrada</h3></div>
          <% } %>
        </div>
      <% } else { %>
        <div class="results-column">
          <div class="stats-line"><%= statsLabel %></div>
          <% const sponsoredSlots = sponsored ? sponsored.slots : null; %>
          <% if (sponsoredSlots && sponsoredSlots.top && sponsoredSlots.top.length > 0) { %>
            <section class="sponsored-section" aria-label="Resultados patrocinados">
              <div class="sponsored-section-header">
                <div>
                  <strong>Patrocinados</strong>
                  <span><%= sponsored.summaryLabel %></span>
                </div>
              </div>
              <div class="sponsored-stack">
                <% sponsoredSlots.top.forEach((sponsor) => { %>
                  <article class="result-card result-card-sponsored">
                    <div class="sponsored-site-line">
                      <div class="sponsored-site-favicon">
                        <span class="material-icons">ads_click</span>
                      </div>
                      <div class="sponsored-site-info">
                        <span class="sponsored-site-name"><%= sponsor.name %></span>
                        <span class="sponsored-site-url"><%= sponsor.urlLabel %></span>
                      </div>
                      <span class="sponsored-label">Patrocinado</span>
                    </div>
                    <h3 class="result-title result-title-sponsored">
                      <a href="<%= sponsor.url %>" target="_blank" rel="noopener noreferrer sponsored" data-sponsor-id="<%= sponsor.id %>">
                        <%= sponsor.name %>
                      </a>
                    </h3>
                    <% if (sponsor.description) { %>
                      <p class="result-description"><%= sponsor.description %></p>
                    <% } %>
                    <% if (sponsor.images && sponsor.images.length > 0) { %>
                      <div class="sponsor-thumbnails">
                        <% sponsor.images.forEach((imgUrl) => { %>
                          <a class="sponsor-thumb-link" href="<%= sponsor.url %>" target="_blank" rel="noopener noreferrer sponsored" data-sponsor-id="<%= sponsor.id %>">
                            <img class="sponsor-thumb" src="<%= imgUrl %>" alt="<%= sponsor.name %>" loading="lazy" onerror="this.parentElement.style.display='none'">
                          </a>
                        <% }) %>
                      </div>
                    <% } %>
                  </article>
                <% }) %>
              </div>
            </section>
          <% } %>
          <% if (results && results.length > 0) { %>
            <% results.forEach((result, index) => { %>
              <%
                const isCatalogDocument = result.recordType === 'catalog_document';
                const detailHref = result.resultUrl || result.detailUrl || result.url;
                const resultHref = result.openUrl || result.downloadUrl || result.url;
                const resultTitle = isCatalogDocument
                  ? [result.documentType, result.documentNumber].filter(Boolean).join(' ') || result.title
                  : result.title;
                const resultSummary = result.summary || result.description || result.content || 'Sem descricao disponivel';
                const openLabel = isCatalogDocument ? 'Abrir arquivo' : 'Abrir pagina';
                const openIcon = isCatalogDocument
                  ? (['doc', 'docx'].includes(String(result.fileExtension || '').toLowerCase()) ? 'article' : 'picture_as_pdf')
                  : 'open_in_new';
                const sourceHref = result.sourceLinkUrl || result.sourceUrl || result.url;
              %>
              <div class="result-card">
                <div class="result-meta-header">
                  <% if (isCatalogDocument) { %>
                    <span class="result-badge">Documento catalogado</span>
                  <% } else { %>
                    <span class="result-badge result-badge-neutral">Pagina indexada</span>
                  <% } %>
                  <% if (result.sourceName) { %>
                    <span class="result-source"><%= result.sourceName %></span>
                  <% } %>
                  <% if (result.fileExtension) { %>
                    <span class="result-format"><%= String(result.fileExtension).toUpperCase() %></span>
                  <% } %>
                </div>
                <div class="result-url">
                  <span class="breadcrumb">
                    <i class="material-icons breadcrumb-icon"><%= isCatalogDocument ? 'description' : 'language' %></i>
                    <%= resultHref %>
                  </span>
                </div>
                <h3 class="result-title">
                  <a href="<%= detailHref %>">
                    <% if (result.highlights && result.highlights.title) { %>
                      <%- result.highlights.title %>
                    <% } else { %>
                      <%= resultTitle %>
                    <% } %>
                  </a>
                </h3>
                <% if (isCatalogDocument) { %>
                  <div class="result-catalog-meta">
                    <% if (result.documentType) { %><span><strong>Tipo:</strong> <%= result.documentType %></span><% } %>
                    <% if (result.documentNumber) { %><span><strong>Numero:</strong> <%= result.documentNumber %></span><% } %>
                    <% if (result.documentDate) { %><span><strong>Documento:</strong> <%= result.documentDate %></span><% } %>
                    <% if (result.publicationDate) { %><span><strong>Publicacao:</strong> <%= result.publicationDate %></span><% } %>
                  </div>
                <% } else { %>
                  <div class="result-catalog-meta">
                    <% if (result.domain) { %><span><strong>Dominio:</strong> <%= result.domain %></span><% } %>
                    <% if (result.crawledAt) { %><span><strong>Indexado:</strong> <%= new Date(result.crawledAt).toLocaleDateString('pt-BR') %></span><% } %>
                  </div>
                <% } %>
                <p class="result-description <%= isCatalogDocument ? 'result-description-catalog' : '' %>">
                  <% if (result.matchSnippetHtml) { %>
                    <%- result.matchSnippetHtml %>
                  <% } else { %>
                    <%= resultSummary.substring(0, 240) %><%= resultSummary.length > 240 ? '...' : '' %>
                  <% } %>
                </p>
                <div class="result-actions">
                  <a href="<%= detailHref %>" class="result-action-link">
                    <span class="material-icons">description</span>
                    Ver detalhes
                  </a>
                  <a href="<%= resultHref %>" target="_blank" rel="noopener noreferrer" class="result-action-link">
                    <span class="material-icons"><%= openIcon %></span>
                    <%= openLabel %>
                  </a>
                  <a href="<%= sourceHref %>" target="_blank" rel="noopener noreferrer" class="result-action-link muted-link">
                    <span class="material-icons">travel_explore</span>
                    Ver fonte
                  </a>
                </div>
              </div>
              <% if (sponsoredSlots && sponsoredSlots.inline && sponsoredSlots.inline.some((slot) => slot.insertAfter === (index + 1))) { %>
                <% sponsoredSlots.inline.filter((slot) => slot.insertAfter === (index + 1)).forEach((slot) => { %>
                  <% const sponsor = slot.sponsor; %>
                  <article class="result-card result-card-sponsored result-card-sponsored-inline">
                    <div class="sponsored-site-line">
                      <div class="sponsored-site-favicon">
                        <span class="material-icons">campaign</span>
                      </div>
                      <div class="sponsored-site-info">
                        <span class="sponsored-site-name"><%= sponsor.name %></span>
                        <span class="sponsored-site-url"><%= sponsor.urlLabel %></span>
                      </div>
                      <span class="sponsored-label">Patrocinado</span>
                    </div>
                    <h3 class="result-title result-title-sponsored">
                      <a href="<%= sponsor.url %>" target="_blank" rel="noopener noreferrer sponsored" data-sponsor-id="<%= sponsor.id %>">
                        <%= sponsor.name %>
                      </a>
                    </h3>
                    <% if (sponsor.description) { %>
                      <p class="result-description"><%= sponsor.description %></p>
                    <% } %>
                  </article>
                <% }) %>
              <% } %>
            <% }) %>
          <% } else { %>
            <div class="empty-state compact-empty-state"><h3>Nenhum resultado encontrado</h3></div>
          <% } %>
        </div>

        <% const hasSponsorSidebar = sponsoredSlots && sponsoredSlots.sidebar && sponsoredSlots.sidebar.length > 0; %>
        <% if (sidebar || hasSponsorSidebar) { %>
          <%
            const sidebarSummary = sidebar ? (sidebar.summary || { totalHits, sourceCount: 0, catalogCount: 0, pageCount: 0 }) : null;
            const featuredResult = sidebar ? (sidebar.featuredResult || null) : null;
            const topSources = sidebar ? (sidebar.topSources || []) : [];
            const documentHighlights = sidebar ? (sidebar.documentHighlights || []) : [];
            const queryIdeas = sidebar ? (sidebar.queryIdeas || []) : [];
          %>
          <aside class="side-column">
            <% if (hasSponsorSidebar) { %>
              <div class="side-card sponsor-policy-card">
                <h4>Inventario patrocinado</h4>
                <p><%= sponsored.summaryLabel %></p>
                <% if (sponsored.hiddenCount > 0) { %>
                  <small><%= sponsored.hiddenCount %> ficaram em rotacao para nao poluir esta pagina.</small>
                <% } %>
              </div>
              <% sponsoredSlots.sidebar.forEach(function(s) { %>
                <div class="side-card side-card-sponsor">
                  <div class="sponsor-side-header">
                    <span class="sponsored-label">Patrocinado</span>
                  </div>
                  <h4 class="sponsor-side-name">
                    <a href="<%= s.url %>" target="_blank" rel="noopener noreferrer sponsored" data-sponsor-id="<%= s.id %>">
                      <%= s.name %>
                    </a>
                  </h4>
                  <% if (s.description) { %>
                    <p class="sponsor-side-desc"><%= s.description %></p>
                  <% } %>
                  <% const sImgs = Array.isArray(s.images) ? s.images.filter(Boolean) : []; %>
                  <% if (sImgs.length > 0) { %>
                    <div class="sponsor-side-images">
                      <% sImgs.slice(0, 3).forEach(function(imgUrl) { %>
                        <a href="<%= s.url %>" target="_blank" rel="noopener noreferrer sponsored" data-sponsor-id="<%= s.id %>">
                          <img src="<%= imgUrl %>" alt="<%= s.name %>" loading="lazy" onerror="this.parentElement.style.display='none'">
                        </a>
                      <% }); %>
                    </div>
                  <% } %>
                  <div class="sponsor-side-url"><%= s.url.replace(/^https?:\/\//, '').replace(/\/$/, '') %></div>
                </div>
              <% }); %>
            <% } %>
            <% if (sidebar) { %>
            <div class="side-card">
              <h4>Panorama da busca</h4>
              <div class="search-summary-grid">
                <div class="summary-stat">
                  <strong><%= sidebarSummary.totalHits %></strong>
                  <span>resultados</span>
                </div>
                <div class="summary-stat">
                  <strong><%= sidebarSummary.sourceCount %></strong>
                  <span>fontes</span>
                </div>
                <div class="summary-stat">
                  <strong><%= sidebarSummary.catalogCount %></strong>
                  <span>catalogados</span>
                </div>
                <div class="summary-stat">
                  <strong><%= sidebarSummary.pageCount %></strong>
                  <span>paginas</span>
                </div>
              </div>
            </div>
            <% if (featuredResult) { %>
              <div class="side-card side-card-featured">
                <h4>Destaque desta busca</h4>
                <a href="<%= featuredResult.detailUrl || featuredResult.openUrl || '#' %>" class="featured-result-link">
                  <strong><%= featuredResult.title || 'Resultado em destaque' %></strong>
                  <span><%= featuredResult.sourceName || 'Origem desconhecida' %></span>
                  <p><%= featuredResult.snippet || 'Abra este resultado para ver os detalhes completos.' %></p>
                </a>
                <div class="featured-actions">
                  <a href="<%= featuredResult.detailUrl || featuredResult.openUrl || '#' %>">Ver detalhes</a>
                  <a href="<%= featuredResult.openUrl || featuredResult.detailUrl || '#' %>" target="_blank" rel="noopener noreferrer">
                    <%= featuredResult.isCatalogDocument ? 'Abrir arquivo' : 'Abrir pagina' %>
                  </a>
                </div>
              </div>
            <% } %>
            <% if (topSources.length > 0) { %>
              <div class="side-card">
                <h4>Filtrar por fonte</h4>
                <div class="side-list">
                  <% topSources.forEach((item) => { %>
                    <a href="<%= item.href %>" class="side-list-item <%= item.active ? 'active' : '' %>">
                      <span><%= item.label %></span>
                      <strong><%= item.count %></strong>
                    </a>
                  <% }) %>
                </div>
              </div>
            <% } %>
            <% if (documentHighlights.length > 0) { %>
              <div class="side-card">
                <h4>Tipos em evidencia</h4>
                <div class="people-list">
                  <% documentHighlights.forEach((item) => { %>
                    <a href="<%= item.href %>" class="people-item">
                      <%= item.label %>
                      <small><%= item.count %></small>
                    </a>
                  <% }) %>
                </div>
              </div>
            <% } %>
            <% if (queryIdeas.length > 0) { %>
              <div class="side-card">
                <h4>Explorar termos proximos</h4>
                <ul class="related-list">
                  <% queryIdeas.forEach((item) => { %>
                    <li>
                      <a href="<%= item.href %>">
                        <i class="material-icons">manage_search</i>
                        <%= item.label %>
                      </a>
                    </li>
                  <% }) %>
                </ul>
              </div>
            <% } %>
            <% } %>
          </aside>
        <% } %>
      <% } %>
    </div>

    <% if (pagination) { %>
      <div class="pagination pagination-page">
        <% if (pagination.previousUrl) { %>
          <a href="<%= pagination.previousUrl %>">&laquo; Anterior</a>
        <% } %>
        <span class="current">Pagina <%= pagination.currentPage %> de <%= pagination.totalPages %></span>
        <% if (pagination.nextUrl) { %>
          <a href="<%= pagination.nextUrl %>">Proxima &raquo;</a>
        <% } %>
      </div>
    <% } %>
  <% } %>

  <div class="image-modal" id="imageModal">
    <div class="modal-overlay" data-close-modal="true"></div>
    <div class="modal-content">
      <div class="modal-header">
        <strong>Detalhes da Imagem</strong>
        <button class="modal-close" type="button" data-close-modal="true">
          <span class="material-icons">close</span>
        </button>
      </div>
      <div class="modal-body">
        <img id="modalImage" src="" alt="">
        <h3 id="modalTitle"></h3>
        <p id="modalDomain"></p>
        <a id="modalUrl" href="" target="_blank" rel="noopener noreferrer">
          <span class="material-icons">link</span>
          <span id="modalUrlText"></span>
        </a>
        <a id="modalOpenBtn" href="" target="_blank" rel="noopener noreferrer" class="open-btn">
          <span class="material-icons">open_in_new</span>
          Abrir pagina original
        </a>
      </div>
    </div>
  </div>

  <%- include('./partials/location-modal') %>
  <script src="/js/search-ui.js"></script>
  <script src="/js/location-ui.js"></script>
  <script>
    document.querySelectorAll('a[data-sponsor-id]').forEach(function(link) {
      link.addEventListener('click', function() {
        var id = link.getAttribute('data-sponsor-id');
        navigator.sendBeacon('/api/sponsors/' + id + '/click');
      });
    });
  </script>
</body>
</html>
