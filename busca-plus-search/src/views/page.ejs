<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= safeTitle %> - Busca+</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;800&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link rel="stylesheet" href="/css/page.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body data-search-query="<%= query || '' %>" data-search-focus="<%= focus || '' %>" data-page-id="<%= page.id || '' %>">
  <div class="page-shell">
    <header class="page-topbar">
      <a href="javascript:history.back()" class="back-link">
        <span class="material-icons">arrow_back</span>
        Voltar
      </a>
      <div class="page-topbar-actions">
        <button type="button" class="nav-auth-btn nav-auth-btn-compact" data-auth-open="login">Login</button>
        <a href="/profile" class="nav-profile-link nav-profile-link-compact" data-auth-profile-link="true" hidden>
          <img src="" alt="Foto de perfil" class="nav-profile-avatar" data-auth-avatar="true">
          <span data-auth-name="true">Meu perfil</span>
        </a>
        <% if (query) { %>
        <span class="search-context-badge">
          <span class="material-icons">search</span>
          "<strong id="searchQueryDisplay"><%= query %></strong>"
        </span>
        <% } %>
        <a href="/" class="page-logo" aria-label="Pagina inicial">Busca<span>+</span></a>
      </div>
    </header>

    <main class="page-detail">
      <article class="page-article">
        <header class="article-header">
          <div class="article-eyebrow">
            <span class="material-icons" style="font-size:12px"><%= isCatalogDocument ? 'description' : 'language' %></span>
            <%= isCatalogDocument ? 'Documento oficial' : 'Pagina indexada' %>
          </div>

          <h1 class="page-title"><%= safeTitle %></h1>

          <div class="page-meta">
            <% if (page.sourceName) { %><span><%= page.sourceName %></span><% } %>
            <% if (page.domain) { %><span class="sep">·</span><span><%= page.domain %></span><% } %>
            <% if (publishedDate) { %><span class="sep">·</span><span><%= publishedDate %></span><% } %>
          </div>

          <% if (leadExcerpt && !isCatalogDocument) { %>
            <p class="page-lead"><%= leadExcerpt %></p>
          <% } %>
        </header>

        <div class="page-actions">
          <button
            type="button"
            class="page-action page-action-ai<%= aiPageEnabled ? '' : ' page-action-disabled' %>"
            data-ai-summary-trigger="true"
            <%= aiPageEnabled ? '' : 'disabled title="IA desativada nas configuracoes"' %>
          >
            <span class="material-icons">auto_awesome</span>
            <span data-ai-summary-button-label="true"><%= aiPageEnabled ? 'Resumir com IA' : 'IA desativada' %></span>
          </button>
          <a href="<%= openUrl %>" target="_blank" rel="noopener noreferrer" class="page-action page-action-primary">
            <span class="material-icons"><%= isCatalogDocument ? 'description' : 'open_in_new' %></span>
            <%= isCatalogDocument ? 'Abrir arquivo original' : 'Abrir pagina original' %>
          </a>
          <% if (sourceHref && sourceHref !== openUrl) { %>
            <a href="<%= sourceHref %>" target="_blank" rel="noopener noreferrer" class="page-action page-action-secondary">
              <span class="material-icons">travel_explore</span>
              Ver fonte
            </a>
          <% } %>
        </div>

        <section class="ai-summary-card" data-ai-summary-card="true" hidden>
          <div class="ai-summary-header">
            <div>
              <span class="reading-kicker">Leitura assistida</span>
              <h3>Resumo com IA</h3>
            </div>
            <span class="ai-summary-meta" data-ai-summary-meta="true"></span>
          </div>
          <p class="ai-summary-status" data-ai-summary-status="true"></p>
          <div class="ai-summary-output" data-ai-summary-output="true"></div>
        </section>

        <% if (featuredImage) { %>
          <figure class="page-featured-media">
            <img src="<%= featuredImage %>" alt="<%= safeTitle %>" class="page-featured-image">
            <% if (featuredCaption) { %><figcaption class="page-featured-caption"><%= featuredCaption %></figcaption><% } %>
          </figure>
        <% } %>

        <% if (isCatalogDocument && documentMetaItems.length > 0) { %>
          <dl class="document-summary-grid">
            <% documentMetaItems.forEach((item) => { %>
              <div class="document-summary-item">
                <dt><%= item.label %></dt>
                <dd><%= item.value %></dd>
              </div>
            <% }) %>
          </dl>
        <% } %>

        <section class="reading-card">
          <div class="reading-header">
            <div>
              <span class="reading-kicker"><%= isCatalogDocument ? 'Documento catalogado' : 'Pagina indexada' %></span>
              <h2>Conteudo completo</h2>
            </div>
          </div>
          <div class="reading-content" data-reading-content="true" id="readingContent">
            <%- formattedContentHtml %>
          </div>
        </section>

        <footer class="page-footer-note">
          <% if (snapshotDate) { %><p>Snapshot processado em <%= snapshotDate %>.</p><% } %>
          <p>A visualizacao reflete o conteudo extraido para fins de indexacao.</p>
        </footer>
      </article>
    </main>
  </div>

  <%- include('./partials/auth-shell') %>
  <script src="/js/page-detail.js"></script>
  <script src="/js/auth-ui.js"></script>
  <script src="/js/location-ui.js"></script>
  <% if (query || focus) { %>
  <script>
    window.searchQuery = <%- JSON.stringify(query) %>;
    window.searchFocus = <%- JSON.stringify(focus) %>;
  </script>
  <% } %>
</body>
</html>
