<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title %> - Busca+</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body {
      background-color: #f8f9fa;
    }
    .page-container {
      max-width: 900px;
      margin: 0 auto;
      padding: 20px;
    }
    .back-link {
      margin-bottom: 20px;
    }
    .back-link a {
      color: #0984e3;
      text-decoration: none;
    }
    .back-link a:hover {
      text-decoration: underline;
    }
    .page-card {
      background: white;
      border-radius: 10px;
      padding: 30px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .page-title {
      color: #2d3436;
      margin-bottom: 15px;
    }
    .page-url {
      color: #00b894;
      font-size: 0.9rem;
      margin-bottom: 20px;
      word-break: break-all;
    }
    .page-url a {
      color: inherit;
    }
    .screenshot-container {
      margin: 20px 0;
      text-align: center;
    }
    .screenshot {
      max-width: 100%;
      border-radius: 8px;
      box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    }
    .page-meta {
      background: #f8f9fa;
      border-radius: 8px;
      padding: 15px;
      margin-top: 20px;
    }
    .meta-item {
      display: flex;
      align-items: center;
      margin-bottom: 10px;
    }
    .meta-item:last-child {
      margin-bottom: 0;
    }
    .meta-item i {
      width: 25px;
      color: #0984e3;
    }
    .page-content {
      margin-top: 25px;
      line-height: 1.8;
    }
    .page-content h2, .page-content h3 {
      margin-top: 20px;
      margin-bottom: 10px;
    }
    .keywords {
      margin-top: 20px;
    }
    .keyword-tag {
      display: inline-block;
      background: #e3f2fd;
      color: #0984e3;
      padding: 5px 12px;
      border-radius: 15px;
      font-size: 0.85rem;
      margin-right: 8px;
      margin-bottom: 8px;
    }
    .actions {
      margin-top: 25px;
      padding-top: 20px;
      border-top: 1px solid #eee;
    }
  </style>
</head>
<body>
  <div class="page-container">
    <!-- Back Link -->
    <div class="back-link">
      <a href="/"><i class="bi bi-arrow-left"></i> Voltar para busca</a>
    </div>

    <!-- Page Card -->
    <div class="page-card">
      <h1 class="page-title"><%= page.title %></h1>
      
      <div class="page-url">
        <i class="bi bi-link-45deg"></i>
        <a href="<%= page.url %>" target="_blank"><%= page.url %></a>
      </div>

      <!-- Screenshot -->
      <% if (page.screenshotPath) { %>
        <div class="screenshot-container">
          <img src="<%= page.screenshotPath %>" alt="Screenshot" class="screenshot">
        </div>
      <% } %>

      <!-- Description -->
      <% if (page.description) { %>
        <p class="lead"><%= page.description %></p>
      <% } %>

      <!-- Metadata -->
      <div class="page-meta">
        <div class="row">
          <div class="col-md-6">
            <div class="meta-item">
              <i class="bi bi-globe"></i>
              <span><strong>Fonte:</strong> <%= page.sourceName || 'Desconhecida' %></span>
            </div>
            <div class="meta-item">
              <i class="bi bi-calendar"></i>
              <span><strong>Indexado em:</strong> <%= new Date(page.crawledAt).toLocaleString('pt-BR') %></span>
            </div>
          </div>
          <div class="col-md-6">
            <div class="meta-item">
              <i class="bi bi-eye"></i>
              <span><strong>Visualizações:</strong> Controle não implementado</span>
            </div>
            <div class="meta-item">
              <i class="bi bi-star"></i>
              <span><strong>Relevância:</strong> Alta</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Keywords -->
      <% if (page.keywords && page.keywords.length > 0) { %>
        <div class="keywords">
          <strong>Palavras-chave:</strong>
          <br>
          <% page.keywords.forEach(keyword => { %>
            <span class="keyword-tag"><%= keyword %></span>
          <% }); %>
        </div>
      <% } %>

      <!-- Content Preview -->
      <% if (page.content) { %>
        <div class="page-content">
          <h4>Conteúdo Indexado</h4>
          <p><%= page.content.substring(0, 500) %><% if (page.content.length > 500) { %>...<% } %></p>
        </div>
      <% } %>

      <!-- Actions -->
      <div class="actions">
        <a href="<%= page.url %>" target="_blank" class="btn btn-primary">
          <i class="bi bi-box-arrow-up-right"></i> Acessar página original
        </a>
        <button class="btn btn-outline-secondary" onclick="window.history.back()">
          <i class="bi bi-arrow-left"></i> Voltar
        </button>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>