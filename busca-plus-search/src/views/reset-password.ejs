<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Redefinir senha - Busca+</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/auth.css">
  <style>
    body {
      min-height: 100vh;
      display: grid;
      place-items: center;
      margin: 0;
      font-family: 'Roboto', Arial, sans-serif;
      background: #f4f7fc;
      color: #162033;
    }
    .reset-card {
      width: min(460px, calc(100vw - 24px));
      background: #fff;
      border: 1px solid #dbe3f2;
      border-radius: 24px;
      padding: 28px;
      box-shadow: 0 28px 80px rgba(15, 23, 42, 0.14);
    }
    .reset-card h1 {
      margin: 0 0 10px;
      font-size: 2rem;
      line-height: 1.05;
    }
    .reset-card p {
      margin: 0 0 22px;
      color: #667085;
      line-height: 1.7;
    }
  </style>
</head>
<body>
  <main class="reset-card">
    <h1>Redefinir senha</h1>
    <p>Informe a nova senha para concluir a recuperacao da sua conta.</p>

    <form class="auth-form" id="resetPasswordForm">
      <input type="hidden" name="token" value="<%= token %>">
      <label>
        <span>Nova senha</span>
        <input type="password" name="password" required minlength="6" autocomplete="new-password">
      </label>
      <label>
        <span>Confirmar senha</span>
        <input type="password" name="confirmPassword" required minlength="6" autocomplete="new-password">
      </label>
      <button type="submit" class="auth-submit">Atualizar senha</button>
    </form>
    <p class="auth-feedback" id="resetFeedback" hidden></p>
  </main>

  <script>
    (function resetPasswordPage() {
      const form = document.getElementById('resetPasswordForm');
      const feedback = document.getElementById('resetFeedback');

      function setFeedback(message, isError) {
        feedback.hidden = !message;
        feedback.textContent = message || '';
        feedback.classList.toggle('is-error', Boolean(isError));
      }

      form.addEventListener('submit', async function onSubmit(event) {
        event.preventDefault();
        if (form.password.value !== form.confirmPassword.value) {
          setFeedback('As senhas nao conferem.', true);
          return;
        }

        setFeedback('Atualizando...', false);
        try {
          const response = await fetch('/api/auth/password/reset', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              token: form.token.value,
              password: form.password.value,
            }),
          });
          const data = await response.json();
          if (!response.ok) throw new Error(data.error || 'Falha ao atualizar senha.');
          setFeedback(data.message || 'Senha atualizada.', false);
          setTimeout(function () { window.location.href = '/'; }, 900);
        } catch (error) {
          setFeedback(error.message || 'Falha ao atualizar senha.', true);
        }
      });
    })();
  </script>
</body>
</html>
