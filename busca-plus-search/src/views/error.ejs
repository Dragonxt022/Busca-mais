<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Erro - Busca+</title>
  <style>
    :root {
      color-scheme: light;
      --bg: #f4efe7;
      --panel: #fffdf9;
      --border: rgba(120, 84, 48, 0.16);
      --text: #26190f;
      --muted: #7a6757;
      --accent: #bf5a2a;
      --accent-dark: #9f471d;
      --shadow: 0 24px 60px rgba(64, 34, 12, 0.12);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      font-family: Roboto, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(191, 90, 42, 0.14), transparent 30%),
        radial-gradient(circle at bottom right, rgba(38, 25, 15, 0.08), transparent 28%),
        linear-gradient(180deg, #fbf7f1 0%, var(--bg) 100%);
    }

    .error-container {
      text-align: center;
      width: min(100%, 560px);
      padding: 40px 32px;
      border: 1px solid var(--border);
      border-radius: 28px;
      background: var(--panel);
      box-shadow: var(--shadow);
    }

    .error-icon {
      width: 92px;
      height: 92px;
      margin: 0 auto 20px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      font-size: 3rem;
      color: var(--accent);
      background: rgba(191, 90, 42, 0.12);
    }

    .error-code {
      font-size: 3rem;
      font-weight: bold;
      color: var(--text);
      margin-bottom: 10px;
    }

    .error-message {
      font-size: 1.2rem;
      line-height: 1.6;
      color: var(--muted);
      margin-bottom: 30px;
    }

    .home-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 48px;
      padding: 0 24px;
      border-radius: 999px;
      border: 0;
      background: var(--accent);
      color: #fff;
      text-decoration: none;
      font-weight: 700;
      transition: background-color 0.2s ease, transform 0.2s ease;
    }

    .home-btn:hover,
    .home-btn:focus-visible {
      background: var(--accent-dark);
      transform: translateY(-1px);
    }

    .dev-details {
      margin-top: 28px;
      padding-top: 24px;
      border-top: 1px solid var(--border);
      text-align: left;
    }

    .dev-details summary {
      cursor: pointer;
      color: var(--muted);
      font-weight: 700;
    }

    .dev-details pre {
      margin: 14px 0 0;
      padding: 16px;
      overflow: auto;
      border-radius: 16px;
      background: #f7efe5;
      color: #563b28;
      font-size: 0.9rem;
      white-space: pre-wrap;
      word-break: break-word;
    }

    @media (max-width: 640px) {
      body {
        padding: 16px;
      }

      .error-container {
        padding: 32px 20px;
        border-radius: 24px;
      }

      .error-code {
        font-size: 2.4rem;
      }

      .error-message {
        font-size: 1rem;
      }
    }
  </style>
</head>
<body>
  <div class="error-container">
    <div class="error-icon" aria-hidden="true">!</div>
    <div class="error-code">
      <%= error.status || 500 %>
    </div>
    <p class="error-message"><%= message %></p>
    <a href="/" class="home-btn">
      <span aria-hidden="true">←</span>
      <span>Voltar para a pagina inicial</span>
    </a>
    <% if (process.env.NODE_ENV === 'development') { %>
      <div class="dev-details">
        <details>
          <summary>Detalhes do erro</summary>
          <pre><%= JSON.stringify(error, null, 2) %></pre>
        </details>
      </div>
    <% } %>
  </div>
</body>
</html>
