# =============================================================
# Busca+ Produção — copie para .env e preencha os valores
# =============================================================

# --- PostgreSQL ---
POSTGRES_USER=buscaplus
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE
POSTGRES_DB=buscaplus

# --- Typesense ---
# Gere uma chave aleatória: openssl rand -hex 32
TYPESENSE_API_KEY=TROQUE_POR_CHAVE_ALEATORIA

# --- Crawler ---
CRAWLER_TIMEOUT=30000
CRAWLER_MAX_DEPTH=3
CRAWLER_MAX_PAGES=100

# URL pública do serviço de admin/crawler (usada no front-end)
CRAWLER_EXTERNAL_URL=https://admin.seudominio.com.br

# --- IA (escolha um provider) ---
# Opção 1: Ollama (LLM local, requer container ou serviço separado)
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# Opção 2: Google Gemini (requer chave de API)
# AI_PROVIDER=google
# GOOGLE_AI_API_KEY=SUA_CHAVE_GOOGLE_AQUI
# GOOGLE_AI_MODEL=gemini-2.0-flash

AI_SUMMARY_MAX_CHARACTERS=12000
