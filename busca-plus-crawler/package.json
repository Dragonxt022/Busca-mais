{
  "name": "busca-plus-crawler",
  "version": "1.0.0",
  "description": "Serviço coletor e indexador do Busca+",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "worker": "node src/workers/index.js",
    "migrate": "npx sequelize-cli db:migrate",
    "seed": "npx sequelize-cli db:seed:all",
    "init-db": "node src/scripts/init-db.js",
    "init-typesense": "node src/scripts/init-typesense.js",
    "init": "npm run init-db && npm run init-typesense"
  },
  "dependencies": {
    "express": "^5.0.0",
    "sequelize": "^6.37.0",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "sqlite3": "^5.1.7",
    "mysql2": "^3.9.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.3.0",
    "playwright": "^1.41.0",
    "cheerio": "^1.0.0-rc.12",
    "typesense": "^1.7.0",
    "dotenv": "^16.4.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "ejs": "^3.1.9",
    "uuid": "^9.0.0",
    "crypto-js": "^4.2.0",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "sequelize-cli": "^6.6.0"
  }
}
