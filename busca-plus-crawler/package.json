{
  "name": "busca-plus-crawler",
  "version": "1.0.0",
  "description": "Serviço coletor e indexador do Busca+",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "worker": "node src/workers/index.js",
    "install:browser": "npx playwright install chromium",
    "ensure:browser": "node src/scripts/ensure-playwright.js",
    "migrate": "npx sequelize-cli db:migrate",
    "seed": "npx sequelize-cli db:seed:all",
    "seed:sponsors": "npx sequelize-cli db:seed --seed seeders/20260418000100-demo-sponsors.js",
    "init-db": "node src/scripts/init-db.js",
    "init-typesense": "node src/scripts/init-typesense.js",
    "init": "npm run ensure:browser && npm run init-db && npm run init-typesense"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.99",
    "bullmq": "^5.0.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.0",
    "ejs": "^3.1.9",
    "express": "^5.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.9.0",
    "node-cron": "^3.0.3",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^3.11.174",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "playwright": "^1.41.0",
    "sequelize": "^6.37.0",
    "sharp": "^0.34.5",
    "sqlite3": "^5.1.7",
    "tesseract.js": "^7.0.0",
    "typesense": "^1.7.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "sequelize-cli": "^6.6.0"
  }
}
