<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-4 border-bottom">
  <h1 class="h2"><i class="bi bi-search me-2"></i>Logs de Busca</h1>
</div>

<div class="card mb-4">
  <div class="card-header">
    <h5 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Termos Mais Pesquisados (Últimos 7 dias)</h5>
  </div>
  <div class="card-body">
    <% if (stats?.topSearches?.length > 0) { %>
      <div class="list-group">
        <% stats.topSearches.forEach((term, index) => { %>
          <div class="list-group-item d-flex justify-content-between align-items-center">
            <div>
              <span class="badge bg-primary me-2">#<%= index + 1 %></span>
              <strong>"<%= term.query %>"</strong>
            </div>
            <span class="badge bg-secondary"><%= term.count %> vezes</span>
          </div>
        <% }); %>
      </div>
      <div class="mt-3 text-center">
        <small class="text-muted">Total de buscas no período: <%= stats?.totalSearches || 0 %></small>
      </div>
    <% } else { %>
      <p class="text-center text-muted mb-0">Nenhum dado de busca disponível</p>
    <% } %>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h5 class="mb-0">Buscas Recentes</h5>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>Termo Pesquisado</th>
            <th>Resultados</th>
            <th>Data/Hora</th>
          </tr>
        </thead>
        <tbody>
          <% if (data?.data?.length > 0) { %>
            <% data.data.forEach(log => { %>
              <tr>
                <td><strong>"<%= log.query %>"</strong></td>
                <td><%= log.total_results || 0 %> resultados</td>
                <td><small><%= new Date(log.created_at).toLocaleString('pt-BR') %></small></td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="3" class="text-center text-muted py-4">Nenhum log de busca encontrado</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <% if (data?.pages > 1) { %>
    <div class="card-footer">
      <nav>
        <ul class="pagination justify-content-center mb-0">
          <% for (let i = 1; i <= data.pages; i++) { %>
            <li class="page-item <%= data.page === i ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %>"><%= i %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    </div>
  <% } %>
</div>
