<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-4 border-bottom">
  <h1 class="h4 mb-0 fw-bold"><i class="bi bi-file-earmark-text me-2 text-primary"></i>Páginas Coletadas</h1>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="card stat-card">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-files"></i></div>
        <div>
          <div class="fw-bold fs-5"><%= data?.progress?.total || 0 %></div>
          <small class="text-muted">Total</small>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="icon bg-success bg-opacity-10 text-success"><i class="bi bi-check2-circle"></i></div>
        <div>
          <div class="fw-bold fs-5 text-success"><%= data?.progress?.indexed || 0 %></div>
          <small class="text-muted">Indexadas</small>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-hourglass-split"></i></div>
        <div>
          <div class="fw-bold fs-5 text-warning"><%= data?.progress?.pending || 0 %></div>
          <small class="text-muted">Pendentes</small>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card stat-card">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="icon bg-danger bg-opacity-10 text-danger"><i class="bi bi-exclamation-triangle"></i></div>
        <div>
          <div class="fw-bold fs-5 text-danger"><%= data?.progress?.error || 0 %></div>
          <small class="text-muted">Erros</small>
        </div>
      </div>
    </div>
  </div>
</div>

<% const pct = data?.progress?.progressPercent || 0; %>
<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <small class="fw-semibold text-muted text-uppercase" style="letter-spacing:.06em;font-size:.72rem;">Progresso de Indexação</small>
      <span class="badge <%= pct === 100 ? 'bg-success' : 'bg-primary' %>"><%= pct %>%</span>
    </div>
    <div class="progress" style="height:10px;border-radius:8px;">
      <div class="progress-bar <%= pct === 100 ? 'bg-success' : 'bg-primary' %>"
        role="progressbar" style="width:<%= pct %>%" aria-valuenow="<%= pct %>" aria-valuemin="0" aria-valuemax="100"></div>
    </div>

    <form method="get" class="row g-2 mt-3">
      <div class="col-md-5">
        <div class="input-group input-group-sm">
          <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
          <input type="text" class="form-control" name="search" placeholder="Buscar por título ou URL..." value="<%= pagination?.search || '' %>">
        </div>
      </div>
      <div class="col-md-3">
        <select class="form-select form-select-sm" name="hasError">
          <option value="">Todos os status</option>
          <option value="true" <%= pagination?.hasError === 'true' ? 'selected' : '' %>>Com erros</option>
        </select>
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-primary px-3">Filtrar</button>
        <% if (pagination?.search || pagination?.hasError) { %>
          <a href="/admin/pages" class="btn btn-sm btn-outline-secondary">Limpar</a>
        <% } %>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>Título / URL</th>
            <th>Fonte</th>
            <th>Palavras</th>
            <th>Indexação</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (data?.data?.length > 0) { %>
            <% data.data.forEach(page => { %>
              <tr>
                <td>
                  <div class="fw-semibold text-truncate" style="max-width:320px;">
                    <%= page.title || 'Sem título' %>
                  </div>
                  <a href="<%= page.url %>" target="_blank" class="text-muted small text-truncate d-block" style="max-width:320px;">
                    <i class="bi bi-link-45deg"></i><%= page.url %>
                  </a>
                </td>
                <td>
                  <span class="badge bg-light text-dark border"><%= page.source?.name || '—' %></span>
                </td>
                <td>
                  <small class="text-muted"><%= (page.word_count || 0).toLocaleString('pt-BR') %></small>
                </td>
                <td>
                  <% if (page.last_indexed_at) { %>
                    <span class="badge bg-success-subtle text-success border border-success-subtle">
                      <i class="bi bi-check-circle me-1"></i>Indexada
                    </span>
                    <small class="text-muted d-block mt-1"><%= new Date(page.last_indexed_at).toLocaleDateString('pt-BR') %></small>
                  <% } else if (page.has_error) { %>
                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle" title="<%= page.error_message || '' %>">
                      <i class="bi bi-exclamation-triangle me-1"></i>Erro
                    </span>
                    <% if (page.error_message) { %>
                      <small class="text-danger d-block mt-1 text-truncate" style="max-width:180px;" title="<%= page.error_message %>">
                        <%= page.error_message.substring(0, 50) %>
                      </small>
                    <% } %>
                  <% } else { %>
                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle">
                      <i class="bi bi-hourglass me-1"></i>Pendente
                    </span>
                  <% } %>
                </td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <a href="/admin/pages/<%= page.id %>" class="btn btn-outline-secondary" title="Ver detalhes">
                      <i class="bi bi-eye"></i>
                    </a>
                    <a href="<%= page.url %>" target="_blank" class="btn btn-outline-secondary" title="Abrir original">
                      <i class="bi bi-box-arrow-up-right"></i>
                    </a>
                    <button class="btn btn-outline-primary" onclick="reindexPage('<%= page.id %>')" title="Reindexar">
                      <i class="bi bi-arrow-repeat"></i>
                    </button>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="5" class="text-center text-muted py-5">
                <i class="bi bi-file-earmark fs-1 d-block mb-2 opacity-25"></i>
                Nenhuma página encontrada
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <% if (data?.pages > 1) { %>
    <div class="card-footer bg-white">
      <nav>
        <ul class="pagination pagination-sm justify-content-center mb-0">
          <% for (let i = 1; i <= data.pages; i++) { %>
            <li class="page-item <%= data.page === i ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %><%= pagination?.search ? '&search=' + encodeURIComponent(pagination.search) : '' %><%= pagination?.hasError ? '&hasError=' + pagination.hasError : '' %>"><%= i %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    </div>
  <% } %>
</div>

<script>
  async function reindexPage(pageId) {
    try {
      await axios.post('/api/pages/' + pageId + '/reindex');
      alert('Página reindexada com sucesso!');
    } catch (error) {
      alert('Erro: ' + (error.response?.data?.error || error.message));
    }
  }
</script>
