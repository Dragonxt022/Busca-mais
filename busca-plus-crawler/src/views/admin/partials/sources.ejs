<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-4 border-bottom">
  <h1 class="h4 mb-0 fw-bold"><i class="bi bi-globe2 me-2 text-primary"></i>Fontes de Página</h1>
  <div class="btn-toolbar mb-2 mb-md-0 gap-2">
    <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#exportSourceModal">
      <i class="bi bi-download me-1"></i> Exportar
    </button>
    <button class="btn btn-outline-primary btn-sm" type="button" onclick="openSourceImportModal()">
      <i class="bi bi-upload me-1"></i> Importar CSV
    </button>
    <button class="btn btn-primary btn-sm" onclick="openSourceModal()">
      <i class="bi bi-plus-lg me-1"></i> Nova Fonte
    </button>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th>Nome</th>
            <th>URL</th>
            <th>Categoria</th>
            <th>Paginas</th>
            <th>Agenda</th>
            <th>Status</th>
            <th>Acoes</th>
          </tr>
        </thead>
        <tbody>
          <% if (data && data.length > 0) { %>
            <% data.forEach((source) => { %>
              <tr>
                <td>
                  <strong><%= source.name %></strong>
                  <% if (source.state || source.city) { %>
                    <div><small class="text-muted"><%= [source.city, source.state].filter(Boolean).join(' - ') %></small></div>
                  <% } %>
                </td>
                <td><small><a href="<%= source.base_url %>" target="_blank"><%= source.base_url.substring(0, 50) %>...</a></small></td>
                <td><span class="badge bg-info"><%= source.category || 'geral' %></span></td>
                <td>
                  <div><strong><%= source.pageCount || 0 %></strong></div>
                  <div class="progress mt-2" style="height: 6px;">
                    <div
                      class="progress-bar <%= source.indexProgress?.progressPercent === 100 ? 'bg-success' : 'bg-primary' %>"
                      role="progressbar"
                      style="width: <%= source.indexProgress?.progressPercent || 0 %>%"
                      aria-valuenow="<%= source.indexProgress?.progressPercent || 0 %>"
                      aria-valuemin="0"
                      aria-valuemax="100"
                    ></div>
                  </div>
                  <small class="text-muted d-block mt-1">
                    <%= source.indexProgress?.indexedPages || 0 %> indexadas, <%= source.indexProgress?.pendingPages || 0 %> pendentes
                    <% if ((source.indexProgress?.errorPages || 0) > 0) { %>
                      , <span class="text-danger"><%= source.indexProgress.errorPages %> com erro</span>
                    <% } %>
                  </small>
                </td>
                <td>
                  <% if (source.schedule) { %>
                    <button class="btn btn-sm btn-outline-warning" onclick="openScheduleModal('<%= source.id %>', '<%= source.schedule %>')" title="Editar agenda">
                      <i class="bi bi-clock"></i> <%= source.schedule %>
                    </button>
                  <% } else { %>
                    <button class="btn btn-sm btn-outline-secondary" onclick="openScheduleModal('<%= source.id %>', '')" title="Definir agenda">
                      <i class="bi bi-clock"></i>
                    </button>
                  <% } %>
                </td>
                <td>
                  <span class="badge <%= source.is_active ? 'bg-success' : 'bg-secondary' %>">
                    <%= source.is_active ? 'Ativa' : 'Inativa' %>
                  </span>
                </td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-primary" onclick="startCrawl('<%= source.id %>')" title="Iniciar coleta">
                      <i class="bi bi-play"></i>
                    </button>
                    <button class="btn btn-outline-secondary" onclick="openSourceModal('<%= source.id %>')" title="Editar">
                      <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn btn-outline-danger" onclick="deleteSource('<%= source.id %>')" title="Excluir">
                      <i class="bi bi-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="7" class="text-center text-muted py-4">Nenhuma fonte cadastrada</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="modal fade" id="addSourceModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="sourceModalTitle">Nova Fonte</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="addSourceForm">
        <div class="modal-body">
          <input type="hidden" name="id" id="sourceId">
          <div class="mb-3">
            <label class="form-label">Nome</label>
            <input type="text" class="form-control" name="name" required>
          </div>
          <div class="mb-3">
            <label class="form-label">URL Base</label>
            <input type="url" class="form-control" name="url" placeholder="https://exemplo.com" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Categoria</label>
            <select class="form-select" name="category">
              <option value="general">Geral</option>
              <option value="news">Noticias</option>
              <option value="blog">Blog</option>
              <option value="government">Governo</option>
              <option value="documentation">Documentacao</option>
              <option value="other">Outro</option>
            </select>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-md-5">
              <label class="form-label">Estado</label>
              <select class="form-select" name="state" id="addSourceState" required>
                <option value="">Selecione...</option>
                <% [['AC','Acre'],['AL','Alagoas'],['AP','Amapa'],['AM','Amazonas'],['BA','Bahia'],['CE','Ceara'],['DF','Distrito Federal'],['ES','Espirito Santo'],['GO','Goias'],['MA','Maranhao'],['MT','Mato Grosso'],['MS','Mato Grosso do Sul'],['MG','Minas Gerais'],['PA','Para'],['PB','Paraiba'],['PR','Parana'],['PE','Pernambuco'],['PI','Piaui'],['RJ','Rio de Janeiro'],['RN','Rio Grande do Norte'],['RS','Rio Grande do Sul'],['RO','Rondonia'],['RR','Roraima'],['SC','Santa Catarina'],['SP','Sao Paulo'],['SE','Sergipe'],['TO','Tocantins']].forEach(([uf, nome]) => { %>
                  <option value="<%= uf %>"><%= uf %> - <%= nome %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-7">
              <label class="form-label">Cidade</label>
              <select class="form-select" name="city" id="addSourceCity" required disabled>
                <option value="">Selecione um estado primeiro</option>
              </select>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Profundidade de Coleta</label>
            <input type="number" class="form-control" name="crawlDepth" value="3" min="1" max="5">
          </div>
          <div class="mb-3">
            <label class="form-label">Limite de paginas por coleta</label>
            <input type="number" class="form-control" name="maxPages" min="1" placeholder="Sem limite">
            <small class="text-muted">Mesmo conceito do limite do catalogo. Deixe vazio para usar o padrao por profundidade.</small>
          </div>
          <div class="mb-3">
            <label class="form-label">Tempo entre Requisicoes (ms)</label>
            <input type="number" class="form-control" name="delayBetweenRequests" value="1000" min="100" step="100">
          </div>
          <div class="mb-3">
            <label class="form-label">User Agent</label>
            <input type="text" class="form-control" name="userAgent" placeholder="Opcional">
          </div>
          <div class="mb-3">
            <label class="form-label">Seletor principal do conteudo</label>
            <input type="text" class="form-control" name="contentSelector" placeholder="Ex: .elementor-widget-theme-post-content">
            <small class="text-muted">Opcional. Quando preenchido, a coleta prioriza exatamente esse bloco.</small>
          </div>
          <div class="mb-3">
            <label class="form-label">Seletores para ignorar</label>
            <textarea class="form-control" name="excludeSelectors" rows="4" placeholder="#comments&#10;.comments-area&#10;.related-posts&#10;.elementor-widget-theme-post-content + section"></textarea>
            <small class="text-muted">Um seletor CSS por linha para remover comentarios, "veja tambem", widgets e blocos irrelevantes.</small>
          </div>
          <div class="mb-3">
            <div class="form-check">
              <input type="checkbox" class="form-check-input" name="followInternalLinks" id="followLinks" checked>
              <label class="form-check-label" for="followLinks">Seguir links internos</label>
            </div>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <div class="form-check">
                <input type="checkbox" class="form-check-input" name="paginationEnabled" id="paginationEnabled" checked>
                <label class="form-check-label" for="paginationEnabled">Seguir paginas paginadas</label>
              </div>
            </div>
            <div class="col-md-6">
              <label class="form-label">Limite de paginas de listagem</label>
              <input type="number" class="form-control" name="maxPaginationPages" value="50" min="0" max="500">
            </div>
          </div>
          <div class="mb-3">
            <div class="form-check">
              <input type="checkbox" class="form-check-input" name="downloadImages" id="downloadImages">
              <label class="form-check-label" for="downloadImages">Baixar imagens da pagina</label>
            </div>
          </div>
          <div class="mb-3">
            <div class="form-check">
              <input type="checkbox" class="form-check-input" name="takeScreenshots" id="takeScreenshots">
              <label class="form-check-label" for="takeScreenshots">Capturar screenshots</label>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Link dos resultados de busca</label>
            <select class="form-select" name="resultLinkType" id="sourceResultLinkType">
              <option value="detail_page">Abrir pagina de detalhes</option>
              <option value="direct_document">Ir direto para o documento/link</option>
            </select>
            <small class="text-muted">Controla o destino ao clicar num resultado desta fonte.</small>
          </div>
          <div class="mb-0">
            <div class="form-check">
              <input type="checkbox" class="form-check-input" name="isActive" id="sourceIsActive" checked>
              <label class="form-check-label" for="sourceIsActive">Fonte ativa</label>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary" id="sourceModalSubmit">Cadastrar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div class="modal fade" id="scheduleModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Agendar Coleta</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="scheduleForm">
        <div class="modal-body">
          <input type="hidden" name="sourceId" id="scheduleSourceId">
          <div class="mb-3">
            <label class="form-label">Expressao Cron</label>
            <input type="text" class="form-control" name="schedule" id="scheduleCron" placeholder="0 */6 * * *" required>
            <small class="text-muted">Formato: minuto hora dia mes dia_semana</small>
          </div>
          <div class="mb-3">
            <label class="form-label">Predefinicoes</label>
            <div class="btn-group w-100">
              <button type="button" class="btn btn-outline-secondary btn-sm" onclick="setCron('0 */6 * * *')">6h</button>
              <button type="button" class="btn btn-outline-secondary btn-sm" onclick="setCron('0 */12 * * *')">12h</button>
              <button type="button" class="btn btn-outline-secondary btn-sm" onclick="setCron('0 0 * * *')">Diario</button>
              <button type="button" class="btn btn-outline-secondary btn-sm" onclick="setCron('0 0 * * 0')">Semanal</button>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-danger me-auto" onclick="removeSchedule()">Remover Agenda</button>
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ── Export Modal ── -->
<div class="modal fade" id="exportSourceModal" tabindex="-1">
  <div class="modal-dialog modal-md">
    <div class="modal-content border-0 shadow-lg">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold"><i class="bi bi-download me-2 text-primary"></i>Exportar Dados</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body pt-2 pb-4 px-4">
        <p class="text-muted small mb-3">Selecione o que deseja exportar:</p>

        <a href="/admin/sources/export.csv?mode=sources" class="export-option text-decoration-none" data-bs-dismiss="modal">
          <div class="export-icon bg-primary bg-opacity-10 text-primary">
            <i class="bi bi-collection"></i>
          </div>
          <div>
            <div class="export-title">Somente Fontes</div>
            <p class="export-desc">Configurações e parâmetros das fontes cadastradas. Ideal para backup ou migração.</p>
          </div>
        </a>

        <a href="/admin/sources/export.csv?mode=pages" class="export-option text-decoration-none" data-bs-dismiss="modal">
          <div class="export-icon bg-success bg-opacity-10 text-success">
            <i class="bi bi-file-earmark-text"></i>
          </div>
          <div>
            <div class="export-title">Lista de Páginas Coletadas</div>
            <p class="export-desc">Todas as URLs coletadas com título, descrição e status. Sem conteúdo completo.</p>
          </div>
        </a>

        <a href="/admin/sources/export.csv?mode=full" class="export-option text-decoration-none mb-0" data-bs-dismiss="modal">
          <div class="export-icon bg-info bg-opacity-10 text-info">
            <i class="bi bi-file-earmark-richtext"></i>
          </div>
          <div>
            <div class="export-title">Páginas com Conteúdo Completo</div>
            <p class="export-desc">Inclui o texto completo coletado de cada página. Arquivo maior, ideal para backup total.</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="importSourceCsvModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-upload me-2"></i>Importar Fontes por CSV</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Arquivo CSV</label>
          <input type="file" class="form-control" id="sourceCsvFile" accept=".csv,text/csv">
        </div>
        <div class="mb-3">
          <label class="form-label">Ou cole o CSV</label>
          <textarea class="form-control font-monospace" id="sourceCsvText" rows="10" placeholder="id,name,base_url,type,category,is_active,crawl_depth,follow_internal_links,download_images,take_screenshots,delay_between_requests,user_agent,schedule,state,city,max_pages"></textarea>
        </div>
        <div class="alert alert-info mb-0 small">
          Colunas aceitas: <code>id,name,base_url,type,category,is_active,crawl_depth,follow_internal_links,download_images,take_screenshots,delay_between_requests,user_agent,schedule,state,city,max_pages</code>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" onclick="submitSourceCsvImport()">Importar</button>
      </div>
    </div>
  </div>
</div>

<script>
  const sourceModalEl = document.getElementById('addSourceModal');
  const sourceModal = new bootstrap.Modal(sourceModalEl);
  const sourceImportModal = new bootstrap.Modal(document.getElementById('importSourceCsvModal'));
  const sourceForm = document.getElementById('addSourceForm');
  const sourceLookup = {
    <% (data || []).forEach((source, index) => { %>
      '<%= source.id %>': {
        id: '<%= source.id %>',
        name: <%- JSON.stringify(source.name || '') %>,
        url: <%- JSON.stringify(source.base_url || '') %>,
        category: <%- JSON.stringify(source.category || 'general') %>,
        state: <%- JSON.stringify(source.state || '') %>,
        city: <%- JSON.stringify(source.city || '') %>,
        crawlDepth: <%= Number(source.crawl_depth || 3) %>,
        maxPages: <%= source.max_pages ? Number(source.max_pages) : 'null' %>,
        delayBetweenRequests: <%= Number(source.delay_between_requests || 1000) %>,
        userAgent: <%- JSON.stringify(source.user_agent || '') %>,
        contentSelector: <%- JSON.stringify(source.config_json?.contentSelector || '') %>,
        excludeSelectors: <%- JSON.stringify(Array.isArray(source.config_json?.excludeSelectors) ? source.config_json.excludeSelectors.join('\n') : '') %>,
        paginationEnabled: <%= source.config_json?.paginationEnabled === false ? 'false' : 'true' %>,
        maxPaginationPages: <%= Number(source.config_json?.maxPaginationPages || 50) %>,
        followInternalLinks: <%= source.follow_internal_links !== false ? 'true' : 'false' %>,
        downloadImages: <%= source.download_images ? 'true' : 'false' %>,
        takeScreenshots: <%= source.take_screenshots ? 'true' : 'false' %>,
        isActive: <%= source.is_active ? 'true' : 'false' %>,
        resultLinkType: <%- JSON.stringify(source.result_link_type || 'detail_page') %>,
      }<%= index < (data || []).length - 1 ? ',' : '' %>
    <% }) %>
  };

  function resetSourceForm() {
    sourceForm.reset();
    document.getElementById('sourceId').value = '';
    document.getElementById('sourceModalTitle').textContent = 'Nova Fonte';
    document.getElementById('sourceModalSubmit').textContent = 'Cadastrar';
    sourceForm.querySelector('[name=category]').value = 'general';
    sourceForm.querySelector('[name=crawlDepth]').value = '3';
    sourceForm.querySelector('[name=maxPages]').value = '';
    sourceForm.querySelector('[name=delayBetweenRequests]').value = '1000';
    sourceForm.querySelector('[name=contentSelector]').value = '';
    sourceForm.querySelector('[name=excludeSelectors]').value = '';
    sourceForm.querySelector('[name=followInternalLinks]').checked = true;
    sourceForm.querySelector('[name=paginationEnabled]').checked = true;
    sourceForm.querySelector('[name=maxPaginationPages]').value = '50';
    sourceForm.querySelector('[name=downloadImages]').checked = false;
    sourceForm.querySelector('[name=takeScreenshots]').checked = false;
    sourceForm.querySelector('[name=isActive]').checked = true;
    sourceForm.querySelector('[name=resultLinkType]').value = 'detail_page';
    document.getElementById('addSourceCity').innerHTML = '<option value="">Selecione um estado primeiro</option>';
    document.getElementById('addSourceCity').disabled = true;
  }

  function openSourceImportModal() {
    document.getElementById('sourceCsvFile').value = '';
    document.getElementById('sourceCsvText').value = '';
    sourceImportModal.show();
  }

  async function openSourceModal(sourceId) {
    resetSourceForm();

    if (sourceId) {
      const source = sourceLookup[sourceId];
      if (!source) return;

      document.getElementById('sourceId').value = source.id;
      document.getElementById('sourceModalTitle').textContent = 'Editar Fonte';
      document.getElementById('sourceModalSubmit').textContent = 'Salvar';
      sourceForm.querySelector('[name=name]').value = source.name;
      sourceForm.querySelector('[name=url]').value = source.url;
      sourceForm.querySelector('[name=category]').value = source.category || 'general';
      sourceForm.querySelector('[name=state]').value = source.state || '';
      sourceForm.querySelector('[name=crawlDepth]').value = String(source.crawlDepth || 3);
      sourceForm.querySelector('[name=maxPages]').value = source.maxPages || '';
      sourceForm.querySelector('[name=delayBetweenRequests]').value = String(source.delayBetweenRequests || 1000);
      sourceForm.querySelector('[name=userAgent]').value = source.userAgent || '';
      sourceForm.querySelector('[name=contentSelector]').value = source.contentSelector || '';
      sourceForm.querySelector('[name=excludeSelectors]').value = source.excludeSelectors || '';
      sourceForm.querySelector('[name=followInternalLinks]').checked = !!source.followInternalLinks;
      sourceForm.querySelector('[name=paginationEnabled]').checked = source.paginationEnabled !== false;
      sourceForm.querySelector('[name=maxPaginationPages]').value = String(source.maxPaginationPages ?? 50);
      sourceForm.querySelector('[name=downloadImages]').checked = !!source.downloadImages;
      sourceForm.querySelector('[name=takeScreenshots]').checked = !!source.takeScreenshots;
      sourceForm.querySelector('[name=isActive]').checked = !!source.isActive;
      sourceForm.querySelector('[name=resultLinkType]').value = source.resultLinkType || 'detail_page';

      if (source.state) {
        await populateCitySelect('addSourceState', 'addSourceCity', source.city || '');
      }
    }

    sourceModal.show();
  }

  async function populateCitySelect(stateSelectId, citySelectId, selectedCity) {
    const stateSelect = document.getElementById(stateSelectId);
    const citySelect = document.getElementById(citySelectId);
    const state = stateSelect ? stateSelect.value : '';

    citySelect.disabled = true;

    if (!state) {
      citySelect.innerHTML = '<option value="">Selecione um estado primeiro</option>';
      return;
    }

    citySelect.innerHTML = '<option value="">Carregando cidades...</option>';

    try {
      const response = await fetch('/api/cities?state=' + encodeURIComponent(state));
      const cities = await response.json();
      const items = Array.isArray(cities) ? cities : [];

      citySelect.innerHTML = '<option value="">Selecione...</option>';
      items.forEach((city) => {
        const option = document.createElement('option');
        option.value = city;
        option.textContent = city;
        if (selectedCity && selectedCity === city) {
          option.selected = true;
        }
        citySelect.appendChild(option);
      });

      if (selectedCity && !items.includes(selectedCity)) {
        const option = document.createElement('option');
        option.value = selectedCity;
        option.textContent = selectedCity;
        option.selected = true;
        citySelect.appendChild(option);
      }
    } catch (error) {
      citySelect.innerHTML = '<option value="">Erro ao carregar cidades — digite manualmente</option>';
    } finally {
      citySelect.disabled = false;
    }
  }

  document.getElementById('addSourceState').addEventListener('change', () => {
    populateCitySelect('addSourceState', 'addSourceCity');
  });

  document.getElementById('addSourceForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);
    data.followInternalLinks = form.querySelector('[name=followInternalLinks]').checked;
    data.paginationEnabled = form.querySelector('[name=paginationEnabled]').checked;
    data.maxPaginationPages = parseInt(form.querySelector('[name=maxPaginationPages]').value, 10) || 0;
    data.maxPages = data.maxPages ? parseInt(data.maxPages, 10) || null : null;
    data.downloadImages = form.querySelector('[name=downloadImages]').checked;
    data.takeScreenshots = form.querySelector('[name=takeScreenshots]').checked;
    data.isActive = form.querySelector('[name=isActive]').checked;

    try {
      if (data.id) {
        await axios.put('/api/sources/' + data.id, data);
      } else {
        await axios.post('/api/sources', data);
      }
      sourceModal.hide();
      location.reload();
    } catch (error) {
      alert('Erro: ' + (error.response?.data?.error || error.message));
    }
  });

  document.getElementById('sourceCsvFile').addEventListener('change', async (e) => {
    const [file] = e.target.files || [];
    if (!file) return;
    document.getElementById('sourceCsvText').value = await file.text();
  });

  async function submitSourceCsvImport() {
    const csvText = document.getElementById('sourceCsvText').value.trim();
    if (!csvText) {
      alert('Selecione ou cole um CSV antes de importar.');
      return;
    }

    try {
      const response = await axios.post('/admin/sources/import', { csv_text: csvText });
      sourceImportModal.hide();
      alert(`Importacao concluida: ${response.data.total} processadas (${response.data.created} criadas, ${response.data.updated} atualizadas).`);
      location.reload();
    } catch (error) {
      alert('Erro: ' + (error.response?.data?.error || error.message));
    }
  }

  async function startCrawl(sourceId) {
    try {
      await axios.post('/api/sources/' + sourceId + '/crawl');
      alert('Coleta iniciada!');
    } catch (error) {
      alert('Erro: ' + (error.response?.data?.error || error.message));
    }
  }

  async function deleteSource(sourceId) {
    if (confirm('Tem certeza que deseja excluir esta fonte?')) {
      try {
        await axios.delete('/api/sources/' + sourceId);
        location.reload();
      } catch (error) {
        alert('Erro: ' + (error.response?.data?.error || error.message));
      }
    }
  }

  function openScheduleModal(sourceId, currentSchedule) {
    document.getElementById('scheduleSourceId').value = sourceId;
    document.getElementById('scheduleCron').value = currentSchedule;
    new bootstrap.Modal(document.getElementById('scheduleModal')).show();
  }

  function setCron(cron) {
    document.getElementById('scheduleCron').value = cron;
  }

  document.getElementById('scheduleForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const sourceId = document.getElementById('scheduleSourceId').value;
    const schedule = document.getElementById('scheduleCron').value;

    try {
      await axios.post('/api/scheduler/sources/' + sourceId + '/schedule', { schedule });
      bootstrap.Modal.getInstance(document.getElementById('scheduleModal')).hide();
      location.reload();
    } catch (error) {
      alert('Erro: ' + (error.response?.data?.error || error.message));
    }
  });

  async function removeSchedule() {
    const sourceId = document.getElementById('scheduleSourceId').value;
    if (confirm('Remover agendamento desta fonte?')) {
      try {
        await axios.delete('/api/scheduler/sources/' + sourceId + '/schedule');
        bootstrap.Modal.getInstance(document.getElementById('scheduleModal')).hide();
        location.reload();
      } catch (error) {
        alert('Erro: ' + (error.response?.data?.error || error.message));
      }
    }
  }
</script>
