<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= document.tipo || 'Documento' %> <%= document.numero_ano || '' %> - Busca+</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
          },
          colors: {
            primary: '#005bbf',
            'primary-container': '#1a73e8',
            'on-primary': '#ffffff',
            background: '#f7f9ff',
            surface: '#f7f9ff',
            'surface-container': '#ebeef4',
            'surface-container-low': '#f1f4fa',
            'surface-container-lowest': '#ffffff',
            'surface-container-high': '#e5e8ee',
            'on-surface': '#181c20',
            'on-surface-variant': '#414754',
            outline: '#727785',
            'outline-variant': '#c1c6d6',
            secondary: '#475e8c',
            tertiary: '#9e4300',
          },
          borderRadius: {
            'xl': '0.75rem',
            '2xl': '1rem',
            '3xl': '1.5rem',
          },
          boxShadow: {
            'editorial': '0px 4px 20px rgba(24, 28, 32, 0.06)',
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .prose-custom p { margin-bottom: 1rem; line-height: 1.75; }
  </style>
</head>
<body class="bg-background text-on-surface min-h-screen">
  <!-- TopAppBar -->
  <header class="fixed top-0 w-full z-50 bg-[#f7f9ff]/85 backdrop-blur-lg border-b border-outline-variant/10">
    <div class="max-w-7xl mx-auto px-6 py-3 flex justify-between items-center">
      <div class="flex items-center gap-6">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary-container">search</span>
          <h1 class="text-lg font-bold text-on-surface tracking-tight">Busca+</h1>
        </div>
        <a class="flex items-center gap-2 text-sm font-medium text-on-surface-variant hover:bg-surface-container-low px-3 py-2 rounded-xl transition-colors" href="/admin/catalog/<%= source.id %>/documents">
          <span class="material-symbols-outlined text-sm">arrow_back</span>
          Voltar para lista
        </a>
      </div>
      <div class="flex items-center gap-3">
        <% if (document.download_url) { %>
        <a href="<%= document.download_url %>" target="_blank" class="px-4 py-2 bg-red-600 text-white rounded-full text-sm font-semibold hover:bg-red-700 transition-colors flex items-center gap-2">
          <span class="material-symbols-outlined text-sm">download</span>
          Baixar PDF
        </a>
        <% } %>
        <% if (document.detalhe_url) { %>
        <a href="<%= document.detalhe_url %>" target="_blank" class="px-4 py-2 bg-surface-container text-primary rounded-full text-sm font-semibold hover:bg-surface-container-high transition-colors flex items-center gap-2">
          <span class="material-symbols-outlined text-sm">open_in_new</span>
          Site Original
        </a>
        <% } %>
      </div>
    </div>
  </header>

  <div class="pt-20 pb-10 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Main Content -->
        <main class="flex-1">
          <!-- Header -->
          <div class="mb-8">
            <div class="flex items-center gap-3 mb-4">
              <span class="material-symbols-outlined text-red-500 text-4xl">description</span>
              <div>
                <span class="inline-block px-3 py-1 bg-surface-container rounded-full text-xs font-semibold text-on-surface-variant mb-2">
                  <%= document.extension || 'PDF' %>
                </span>
                <h1 class="text-3xl font-extrabold text-on-surface tracking-tight">
                  <%= document.tipo || 'Documento' %>
                </h1>
                <p class="text-lg text-on-surface-variant font-medium">
                  <%= document.numero_ano || 'Sem número/ano' %>
                </p>
              </div>
            </div>
          </div>

          <!-- Content Card -->
          <div class="bg-surface-container-lowest rounded-3xl p-8 shadow-editorial mb-8">
            <!-- Dates -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8 pb-6 border-b border-outline-variant">
              <% if (document.data_documento) { %>
              <div>
                <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest block mb-1">Data do Doc.</span>
                <p class="text-sm font-semibold"><%= document.data_documento %></p>
              </div>
              <% } %>
              <% if (document.data_publicacao) { %>
              <div>
                <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest block mb-1">Publicacao</span>
                <p class="text-sm font-semibold"><%= document.data_publicacao %></p>
              </div>
              <% } %>
              <div>
                <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest block mb-1">Status</span>
                <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-semibold <%= document.status === 'indexed' ? 'bg-green-100 text-green-700' : document.status === 'error' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700' %>">
                  <% if (document.status === 'indexed') { %>
                    <span class="material-symbols-outlined text-xs">check_circle</span> Indexado
                  <% } else if (document.status === 'error') { %>
                    <span class="material-symbols-outlined text-xs">error</span> Erro
                  <% } else { %>
                    <span class="material-symbols-outlined text-xs">schedule</span> Pendente
                  <% } %>
                </span>
              </div>
              <div>
                <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest block mb-1">ID</span>
                <p class="text-sm font-semibold font-mono"><%= document.external_id %></p>
              </div>
            </div>

            <!-- Description -->
            <% if (document.descricao) { %>
            <div class="mb-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="material-symbols-outlined text-primary text-lg">info</span>
                <h2 class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">Descricao</h2>
              </div>
              <p class="text-on-surface-variant leading-relaxed"><%= document.descricao %></p>
            </div>
            <% } %>

            <!-- Ementa -->
            <% if (document.ementa) { %>
            <div class="bg-surface-container rounded-2xl p-6 border-l-4 border-primary-container">
              <div class="flex items-center gap-2 mb-3">
                <span class="material-symbols-outlined text-primary-container text-lg">summarize</span>
                <h2 class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">Ementa</h2>
              </div>
              <p class="text-on-surface-variant leading-relaxed whitespace-pre-wrap"><%= document.ementa %></p>
            </div>
            <% } %>

            <!-- Metadata -->
            <% if (document.metadata_json) { %>
            <% const hasMetadata = document.metadata_json.assunto || document.metadata_json.origem || document.metadata_json.autores; %>
            <% if (hasMetadata) { %>
            <div class="mt-6 pt-6 border-t border-outline-variant">
              <div class="flex items-center gap-2 mb-4">
                <span class="material-symbols-outlined text-secondary text-lg">label</span>
                <h2 class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">Metadados</h2>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <% if (document.metadata_json.assunto) { %>
                <div class="bg-surface-container rounded-xl p-3">
                  <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest block mb-1">Assunto</span>
                  <p class="text-sm font-medium"><%= document.metadata_json.assunto %></p>
                </div>
                <% } %>
                <% if (document.metadata_json.origem) { %>
                <div class="bg-surface-container rounded-xl p-3">
                  <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest block mb-1">Origem</span>
                  <p class="text-sm font-medium"><%= document.metadata_json.origem %></p>
                </div>
                <% } %>
                <% if (document.metadata_json.autores) { %>
                <div class="bg-surface-container rounded-xl p-3">
                  <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest block mb-1">Autores</span>
                  <p class="text-sm font-medium"><%= document.metadata_json.autores %></p>
                </div>
                <% } %>
              </div>
            </div>
            <% } %>
            <% } %>

            <!-- Index Error -->
            <% if (document.metadata_json && document.metadata_json.last_index_error) { %>
            <div class="mt-6 bg-red-50 border border-red-200 rounded-2xl p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="material-symbols-outlined text-red-600 text-lg">warning</span>
                <h2 class="text-sm font-bold uppercase tracking-widest text-red-700">Erro de Indexacao</h2>
              </div>
              <pre class="text-sm text-red-600 whitespace-pre-wrap font-mono bg-white p-3 rounded-xl"><%= document.metadata_json.last_index_error %></pre>
            </div>
            <% } %>
          </div>
        </main>

        <!-- Sidebar -->
        <aside class="w-full lg:w-80 space-y-6">
          <!-- Info Card -->
          <div class="bg-surface-container-lowest rounded-3xl p-6 shadow-editorial">
            <div class="flex items-center gap-2 mb-6">
              <span class="material-symbols-outlined text-primary text-xl">info</span>
              <h3 class="text-lg font-bold">Informacoes</h3>
            </div>
            <div class="space-y-5">
              <div>
                <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest block mb-1">Fonte</span>
                <p class="text-sm font-semibold"><%= source.name %></p>
              </div>
              <div>
                <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest block mb-1">Criado em</span>
                <p class="text-sm font-semibold">
                  <% if (document.created_at) { %>
                    <%= new Date(document.created_at).toLocaleDateString('pt-BR') %>
                  <% } else { %>
                    -
                  <% } %>
                </p>
              </div>
              <div>
                <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest block mb-1">Atualizado em</span>
                <p class="text-sm font-semibold">
                  <% if (document.updated_at) { %>
                    <%= new Date(document.updated_at).toLocaleDateString('pt-BR') %>
                  <% } else { %>
                    -
                  <% } %>
                </p>
              </div>
            </div>
          </div>

          <!-- Source Link Card -->
          <div class="bg-surface-container-lowest rounded-3xl p-6 shadow-editorial overflow-hidden">
            <div class="flex items-center gap-2 mb-4">
              <span class="material-symbols-outlined text-primary text-xl">link</span>
              <h3 class="text-lg font-bold">Links</h3>
            </div>
            <% if (document.detalhe_url) { %>
            <div class="mb-4">
              <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest block mb-2">URL de Origem</span>
              <div class="bg-surface-container rounded-xl p-3">
                <p class="text-xs break-all font-mono text-on-surface-variant truncate" title="<%= document.detalhe_url %>">
                  <%= document.detalhe_url %>
                </p>
              </div>
            </div>
            <% } %>
            <% if (document.download_url) { %>
            <div>
              <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest block mb-2">URL de Download</span>
              <div class="bg-surface-container rounded-xl p-3">
                <p class="text-xs break-all font-mono text-on-surface-variant truncate" title="<%= document.download_url %>">
                  <%= document.download_url %>
                </p>
              </div>
            </div>
            <% } %>
          </div>

          <!-- Page Images -->
          <% if (pageImages && pageImages.length > 0) { %>
          <div class="bg-surface-container-lowest rounded-3xl p-6 shadow-editorial">
            <div class="flex items-center gap-2 mb-4">
              <span class="material-symbols-outlined text-primary text-xl">image</span>
              <h3 class="text-lg font-bold">Imagens da Pagina (<%= pageImages.length %>)</h3>
            </div>
            <div class="grid grid-cols-3 gap-3">
              <% pageImages.slice(0, 9).forEach(function(img, idx) { %>
              <a href="<%= img.url || img.thumbnailUrl %>" target="_blank" class="aspect-square rounded-xl overflow-hidden bg-surface-container hover:opacity-80 transition-opacity">
                <img 
                  src="<%= img.thumbnailUrl || img.url %>" 
                  alt="<%= img.alt || img.filename || 'Imagem' %>"
                  class="w-full h-full object-cover"
                  onerror="this.src='<%= img.url %>'; this.onerror=null;"
                >
              </a>
              <% }); %>
            </div>
            <% if (pageImages.length > 9) { %>
            <p class="text-xs text-on-surface-variant mt-3 text-center">
              +<%= pageImages.length - 9 %> outras imagens
            </p>
            <% } %>
            <% if (document.sourcePage) { %>
            <div class="mt-4 pt-4 border-t border-outline-variant">
              <a href="/admin/pages/<%= document.sourcePage.id %>" class="flex items-center gap-2 text-sm font-medium text-primary hover:underline">
                <span class="material-symbols-outlined text-sm">open_in_new</span>
                Ver pagina de origem
              </a>
            </div>
            <% } %>
          </div>
          <% } %>

          <!-- Help Text -->
          <div class="px-2">
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-on-surface-variant/50 text-xl">help</span>
              <div>
                <h4 class="text-xs font-bold text-on-surface mb-1">Sobre a Visualizacao</h4>
                <p class="text-xs text-on-surface-variant leading-relaxed">
                  Esta pagina exibe os detalhes do documento conforme processado pelo Busca+. Para versao atualizada, visite o site original.
                </p>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>
</body>
</html>
