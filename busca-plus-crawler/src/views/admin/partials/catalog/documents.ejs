<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-4 border-bottom">
  <div>
    <a href="/admin/catalog" class="btn btn-sm btn-outline-secondary me-2">
      <i class="bi bi-arrow-left"></i>
    </a>
    <h1 class="h2 d-inline"><i class="bi bi-file-earmark-pdf me-2"></i><%= title %></h1>
    <span class="badge bg-secondary ms-2"><%= documents ? documents.length : 0 %> documentos</span>
  </div>
  <div class="btn-group">
    <form action="/admin/catalog/<%= source.id %>/index" method="POST">
      <input type="hidden" name="only_pending" value="on">
      <button type="submit" class="btn btn-sm btn-outline-dark">
        <i class="bi bi-play-circle me-1"></i>Continuar Indexacao
      </button>
    </form>
    <form action="/admin/catalog/<%= source.id %>/index" method="POST" class="ms-2">
      <button type="submit" class="btn btn-sm btn-outline-primary">
        <i class="bi bi-search me-1"></i>Indexar Tudo
      </button>
    </form>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <strong>Progresso da indexacao</strong>
      <span class="badge bg-secondary"><%= progress.progressPercent %>%</span>
    </div>
    <div class="progress" style="height: 10px;">
      <div
        class="progress-bar bg-success"
        role="progressbar"
        style="width: <%= progress.progressPercent %>%"
        aria-valuenow="<%= progress.progressPercent %>"
        aria-valuemin="0"
        aria-valuemax="100"
      ></div>
    </div>
    <div class="row mt-3 g-3">
      <div class="col-md-3"><small class="text-muted d-block">Total</small><strong><%= progress.total %></strong></div>
      <div class="col-md-3"><small class="text-muted d-block">Indexados</small><strong class="text-success"><%= progress.indexed %></strong></div>
      <div class="col-md-3"><small class="text-muted d-block">Pendentes</small><strong class="text-warning"><%= progress.pending %></strong></div>
      <div class="col-md-3"><small class="text-muted d-block">Erros</small><strong class="text-danger"><%= progress.error %></strong></div>
    </div>
    <small class="text-muted d-block mt-3">
      O estado fica salvo por documento. Se a execucao parar, basta continuar a indexacao pelos pendentes.
    </small>
  </div>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Tipo</th>
            <th>Numero/Ano</th>
            <th>Data Doc.</th>
            <th>Data Pub.</th>
            <th>Descricao</th>
            <th>Status</th>
            <th>Acoes</th>
          </tr>
        </thead>
        <tbody>
          <% if (!documents || documents.length === 0) { %>
            <tr>
              <td colspan="7" class="text-center text-muted py-5">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                Nenhum documento catalogado
              </td>
            </tr>
          <% } else { %>
            <% documents.forEach(function(doc) { %>
              <tr>
                <td><span class="badge bg-secondary"><%= doc.tipo || '-' %></span></td>
                <td><small><%= doc.numero_ano || '-' %></small></td>
                <td><small><%= doc.data_documento || '-' %></small></td>
                <td><small><%= doc.data_publicacao || '-' %></small></td>
                <td>
                  <small class="text-truncate d-inline-block" style="max-width: 300px;" title="<%= doc.descricao %>">
                    <%= doc.descricao ? doc.descricao.substring(0, 80) + '...' : '-' %>
                  </small>
                </td>
                <td>
                  <span class="badge badge-status <%= doc.status === 'indexed' ? 'bg-success' : doc.status === 'error' ? 'bg-danger' : 'bg-warning' %>">
                    <%= doc.status || 'pending' %>
                  </span>
                </td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <a href="/admin/pages/<%= doc.id %>?type=catalog" class="btn btn-outline-primary" title="Ver Detalhes">
                      <i class="bi bi-eye"></i>
                    </a>
                    <% if (doc.download_url) { %>
                      <a href="<%= doc.download_url %>" target="_blank" class="btn btn-outline-danger" title="Baixar PDF">
                        <i class="bi bi-file-pdf"></i>
                      </a>
                    <% } %>
                    <% if (doc.detalhe_url) { %>
                      <a href="<%= doc.detalhe_url %>" target="_blank" class="btn btn-outline-info" title="Ver Site Original">
                        <i class="bi bi-box-arrow-up-right"></i>
                      </a>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% if (doc.ementa) { %>
                <tr class="table-secondary">
                  <td colspan="7">
                    <small><strong>Ementa:</strong> <%= doc.ementa %></small>
                    <% if (doc.metadata_json && doc.metadata_json.last_index_error) { %>
                      <br>
                      <small class="text-danger"><strong>Erro de indexacao:</strong> <%= doc.metadata_json.last_index_error %></small>
                    <% } %>
                  </td>
                </tr>
              <% } %>
            <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
