<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-4 border-bottom">
  <h1 class="h4 mb-0 fw-bold"><i class="bi bi-folder2-open me-2 text-primary"></i>Catálogo de Documentos</h1>
  <div class="d-flex flex-wrap gap-2">
    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#exportCatalogModal">
      <i class="bi bi-download me-1"></i>Exportar
    </button>
    <div class="dropdown">
      <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
        <i class="bi bi-upload me-1"></i>Importar
      </button>
      <ul class="dropdown-menu">
        <li><a class="dropdown-item" href="#" onclick="openCatalogImportModal()"><i class="bi bi-collection me-2"></i>Importar Fontes</a></li>
        <li><a class="dropdown-item" href="#" onclick="openDocumentImportModal()"><i class="bi bi-file-earmark-text me-2"></i>Importar Documentos</a></li>
      </ul>
    </div>
    <form action="/admin/catalog/clear-queue" method="POST" class="d-inline">
      <button type="submit" class="btn btn-sm btn-outline-warning" onclick="return confirm('Cancelar todas as execucoes em andamento?')">
        <i class="bi bi-x-circle me-1"></i>Limpar Fila
      </button>
    </form>
    <form action="/admin/catalog/reset-all" method="POST" class="d-inline">
      <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('ATENCAO: Isso ira remover todos os documentos catalogados. Continuar?')">
        <i class="bi bi-trash me-1"></i>Resetar Tudo
      </button>
    </form>
  </div>
</div>

<% if (typeof msg !== 'undefined') { %>
  <% if (msg === 'queue_cleared') { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle me-2"></i>Fila limpa com sucesso!
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% } else if (msg === 'reset_done') { %>
  <div class="alert alert-warning alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle me-2"></i>Catalogo resetado com sucesso!
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% } else if (msg === 'run_started') { %>
  <div class="alert alert-info alert-dismissible fade show" role="alert">
    <i class="bi bi-hourglass-split me-2"></i>Catalogacao iniciada em segundo plano...
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% } else if (msg === 'index_started') { %>
  <div class="alert alert-primary alert-dismissible fade show" role="alert">
    <i class="bi bi-search me-2"></i>Indexacao enfileirada com sucesso...
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% } else if (msg === 'resume_started') { %>
  <div class="alert alert-primary alert-dismissible fade show" role="alert">
    <i class="bi bi-arrow-repeat me-2"></i>Indexacao retomada a partir do estado salvo...
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
  <% } %>
<% } %>

<% const hasRunningJobs = runs && runs.some(r => r.status === 'running'); %>
<% if (hasRunningJobs) { %>
<meta http-equiv="refresh" content="10">
<div class="alert alert-secondary alert-dismissible fade show" role="alert">
  <i class="bi bi-arrow-repeat me-2"></i>Atualizando automaticamente (ha execucoes em andamento)
  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
</div>
<% } %>

<%
  const statsMap = (documentStats || []).reduce((acc, item) => {
    acc[item.status] = Number(item.count || 0);
    return acc;
  }, {});
%>

<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card stat-card bg-primary bg-gradient text-white">
      <div class="card-body d-flex align-items-center">
        <div class="icon bg-white text-primary me-3">
          <i class="bi bi-collection"></i>
        </div>
        <div>
          <h3 class="mb-0"><%= sources ? sources.length : 0 %></h3>
          <small>Fontes Cadastradas</small>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card bg-success bg-gradient text-white">
      <div class="card-body d-flex align-items-center">
        <div class="icon bg-white text-success me-3">
          <i class="bi bi-file-earmark-pdf"></i>
        </div>
        <div>
          <h3 class="mb-0"><%= sources ? sources.reduce((sum, s) => sum + (s.total_documents || 0), 0) : 0 %></h3>
          <small>Documentos Catalogados</small>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card bg-info bg-gradient text-white">
      <div class="card-body d-flex align-items-center">
        <div class="icon bg-white text-info me-3">
          <i class="bi bi-check2-square"></i>
        </div>
        <div>
          <h3 class="mb-0"><%= statsMap.indexed || 0 %></h3>
          <small>Documentos Indexados</small>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card bg-warning bg-gradient text-white">
      <div class="card-body d-flex align-items-center">
        <div class="icon bg-white text-warning me-3">
          <i class="bi bi-hourglass-split"></i>
        </div>
        <div>
          <h3 class="mb-0"><%= (statsMap.pending || 0) + (statsMap.error || 0) %></h3>
          <small>Pendentes para Indexar</small>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-8">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Fontes de Catalogo</h5>
        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#newSourceModal">
          <i class="bi bi-plus-lg me-1"></i>Nova Fonte
        </button>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Nome</th>
                <th>URL</th>
                <th>Status</th>
                <th>Docs</th>
                <th>Ultima Execucao</th>
                <th>Acoes</th>
              </tr>
            </thead>
            <tbody>
              <% if (!sources || sources.length === 0) { %>
                <tr>
                  <td colspan="6" class="text-center text-muted py-4">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    Nenhuma fonte cadastrada
                  </td>
                </tr>
              <% } else { %>
                <% sources.forEach(function(source) { %>
                  <tr>
                    <td>
                      <strong><%= source.name %></strong>
                      <% if (source.auto_update_enabled) { %>
                        <span class="badge bg-warning ms-1" title="Atualizacao automatica"><i class="bi bi-arrow-repeat"></i></span>
                      <% } %>
                      <% if (source.auto_index_after_catalog) { %>
                        <span class="badge bg-info ms-1" title="Indexacao automatica apos catalogacao"><i class="bi bi-search"></i></span>
                      <% } %>
                    </td>
                    <td>
                      <small><a href="<%= source.source_url %>" target="_blank" class="text-truncate d-inline-block" style="max-width: 200px;">
                        <%= source.source_url %>
                      </a></small>
                    </td>
                    <td>
                      <span class="badge badge-status <%= source.last_status === 'success' ? 'bg-success' : source.last_status === 'error' ? 'bg-danger' : source.last_status === 'running' ? 'bg-primary' : 'bg-secondary' %>">
                        <%= source.last_status || 'idle' %>
                      </span>
                    </td>
                    <td>
                      <div><%= source.total_documents || 0 %></div>
                      <div class="progress mt-2" style="height: 6px;">
                        <div
                          class="progress-bar bg-success"
                          role="progressbar"
                          style="width: <%= source.progress.progressPercent %>%"
                          aria-valuenow="<%= source.progress.progressPercent %>"
                          aria-valuemin="0"
                          aria-valuemax="100"
                        ></div>
                      </div>
                      <small class="text-muted d-block mt-1">
                        <%= source.progress.indexed %> indexados, <%= source.progress.pending %> pendentes, <%= source.progress.error %> com erro
                      </small>
                    </td>
                    <td>
                      <% if (source.last_run_at) { %>
                        <small><%= new Date(source.last_run_at).toLocaleString('pt-BR') %></small>
                      <% } else { %>
                        <small class="text-muted">Nunca</small>
                      <% } %>
                    </td>
                    <td>
                      <div class="btn-group btn-group-sm">
                        <a href="/admin/catalog/<%= source.id %>/documents" class="btn btn-outline-secondary" title="Ver Documentos">
                          <i class="bi bi-files"></i>
                        </a>
                        <form action="/admin/catalog/<%= source.id %>/run" method="POST" class="d-inline">
                          <input type="hidden" name="type" value="update">
                          <button type="submit" class="btn btn-outline-primary" title="Atualizar Catalogo">
                            <i class="bi bi-arrow-repeat"></i>
                          </button>
                        </form>
                        <form action="/admin/catalog/<%= source.id %>/run" method="POST" class="d-inline">
                          <input type="hidden" name="type" value="create">
                          <button type="submit" class="btn btn-outline-success" title="Recriar Catalogo">
                            <i class="bi bi-cloud-download"></i>
                          </button>
                        </form>
                        <form action="/admin/catalog/<%= source.id %>/index" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-outline-dark" title="Indexar Documentos">
                            <i class="bi bi-search"></i>
                          </button>
                        </form>
                        <% if (source.progress.resumable) { %>
                          <form action="/admin/catalog/<%= source.id %>/index" method="POST" class="d-inline">
                            <input type="hidden" name="only_pending" value="on">
                            <button type="submit" class="btn btn-outline-warning" title="Continuar Indexacao">
                              <i class="bi bi-play-circle"></i>
                            </button>
                          </form>
                        <% } %>
                        <button type="button" class="btn btn-outline-secondary" title="Editar Fonte" onclick="openEditSourceModal(<%= source.id %>)">
                          <i class="bi bi-pencil"></i>
                        </button>
                        <div class="btn-group">
                          <button type="button" class="btn btn-outline-danger dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" title="Mais opcoes">
                            <i class="bi bi-three-dots-vertical"></i>
                          </button>
                          <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                              <a class="dropdown-item text-danger" href="#" onclick="deleteSource(<%= source.id %>, <%= source.total_documents || 0 %>)">
                                <i class="bi bi-trash me-2"></i>Excluir Fonte
                              </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                              <a class="dropdown-item" href="#" onclick="deleteSource(<%= source.id %>, <%= source.total_documents || 0 %>, true)">
                                <i class="bi bi-trash-fill me-2"></i>Excluir Tudo (Fonte + Docs)
                              </a>
                            </li>
                          </ul>
                        </div>
                      </div>
                      <small class="text-muted d-block mt-2">
                        Estado salvo por documento. Se parar, a continuidade usa os pendentes e erros.
                      </small>
                    </td>
                  </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Historico de Execucoes</h5>
      </div>
      <div class="card-body p-0">
        <div class="list-group list-group-flush">
          <% if (!runs || runs.length === 0) { %>
            <div class="list-group-item text-center text-muted py-4">
              <i class="bi bi-clock-history fs-1 d-block mb-2"></i>
              Nenhuma execucao registrada
            </div>
          <% } else { %>
            <% runs.slice(0, 10).forEach(function(run) { %>
              <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-start">
                  <div>
                    <small class="text-muted d-block">Fonte #<%= run.source_id %></small>
                    <small><%= run.type === 'create' ? 'Criacao' : 'Atualizacao' %></small>
                  </div>
                  <span class="badge badge-status <%= run.status === 'success' ? 'bg-success' : run.status === 'error' ? 'bg-danger' : run.status === 'running' ? 'bg-primary' : 'bg-secondary' %>">
                    <%= run.status %>
                  </span>
                </div>
                <div class="mt-2">
                  <small class="text-muted">
                    <% if (run.started_at) { %>
                      <%= new Date(run.started_at).toLocaleString('pt-BR') %>
                    <% } %>
                  </small>
                  <% if (run.status === 'success') { %>
                    <div class="mt-1">
                      <small><span class="text-success">+<%= run.new_items %></span> novos</small>
                      <small class="ms-2"><span class="text-info">~<%= run.updated_items %></span> atualizados</small>
                      <% if (run.metadata_json && run.metadata_json.queued_for_index) { %>
                        <small class="ms-2"><span class="text-primary"><%= run.metadata_json.queued_for_index %></span> em fila</small>
                      <% } %>
                    </div>
                  <% } else if (run.message) { %>
                    <small class="text-danger d-block mt-1"><%= run.message.substring(0, 80) %></small>
                  <% } %>
                </div>
              </div>
            <% }); %>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="newSourceModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Nova Fonte de Catalogo</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/admin/catalog" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Nome</label>
            <input type="text" name="name" class="form-control" required placeholder="Ex: Publicacoes Cujubim">
          </div>
          <div class="mb-3">
            <label class="form-label">Slug</label>
            <input type="text" name="slug" class="form-control" required placeholder="Ex: cujubim-publicacoes">
            <small class="text-muted">Identificador unico em minusculas</small>
          </div>
          <div class="mb-3">
            <label class="form-label">URL da Fonte</label>
            <input type="url" name="source_url" class="form-control" required placeholder="https://...">
          </div>
          <div class="row g-2 mb-3">
            <div class="col-md-5">
              <label class="form-label">Estado <span class="text-danger">*</span></label>
              <select name="state" class="form-select" required>
                <option value="">Selecione...</option>
                <% [['AC','Acre'],['AL','Alagoas'],['AP','Amapá'],['AM','Amazonas'],['BA','Bahia'],['CE','Ceará'],['DF','Distrito Federal'],['ES','Espírito Santo'],['GO','Goiás'],['MA','Maranhão'],['MT','Mato Grosso'],['MS','Mato Grosso do Sul'],['MG','Minas Gerais'],['PA','Pará'],['PB','Paraíba'],['PR','Paraná'],['PE','Pernambuco'],['PI','Piauí'],['RJ','Rio de Janeiro'],['RN','Rio Grande do Norte'],['RS','Rio Grande do Sul'],['RO','Rondônia'],['RR','Roraima'],['SC','Santa Catarina'],['SP','São Paulo'],['SE','Sergipe'],['TO','Tocantins']].forEach(function(item) { %>
                  <option value="<%= item[0] %>"><%= item[0] %> — <%= item[1] %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-7">
              <label class="form-label">Cidade <span class="text-danger">*</span></label>
              <select name="city" class="form-select" id="catalogSourceCity" required disabled>
                <option value="">Selecione um estado primeiro</option>
              </select>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Agendamento</label>
            <select name="schedule_type" class="form-select">
              <option value="manual">Manual</option>
              <option value="hourly">A cada hora</option>
              <option value="daily">Diario</option>
              <option value="weekly">Semanal</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Limite de Documentos por Catalogação</label>
            <input type="number" name="max_documents" class="form-control" min="1" placeholder="Sem limite">
            <small class="text-muted">Número máximo de documentos por execução (vazio = sem limite)</small>
          </div>
          <div class="mb-3 form-check">
            <input type="checkbox" name="auto_update_enabled" class="form-check-input" id="autoUpdate">
            <label class="form-check-label" for="autoUpdate">Atualizacao automatica</label>
          </div>
          <div class="mb-3 form-check">
            <input type="checkbox" name="auto_index_after_catalog" class="form-check-input" id="autoIndexAfterCatalog">
            <label class="form-check-label" for="autoIndexAfterCatalog">Indexar automaticamente apos catalogacao</label>
          </div>
          <div class="mb-3 form-check">
            <input type="checkbox" name="is_active" class="form-check-input" id="isActive" checked>
            <label class="form-check-label" for="isActive">Ativo</label>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Criar Fonte</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ── Edit Source Modal ── -->
<div class="modal fade" id="editSourceModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Editar Fonte de Catálogo</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="editSourceId">
        <div class="mb-3">
          <label class="form-label">Nome</label>
          <input type="text" id="editSourceName" class="form-control" required>
        </div>
        <div class="mb-3">
          <label class="form-label">URL da Fonte</label>
          <input type="url" id="editSourceUrl" class="form-control" required>
        </div>
        <div class="row g-2 mb-3">
          <div class="col-md-5">
            <label class="form-label">Estado</label>
            <select id="editSourceState" class="form-select">
              <option value="">Nenhum</option>
              <% [['AC','Acre'],['AL','Alagoas'],['AP','Amapá'],['AM','Amazonas'],['BA','Bahia'],['CE','Ceará'],['DF','Distrito Federal'],['ES','Espírito Santo'],['GO','Goiás'],['MA','Maranhão'],['MT','Mato Grosso'],['MS','Mato Grosso do Sul'],['MG','Minas Gerais'],['PA','Pará'],['PB','Paraíba'],['PR','Paraná'],['PE','Pernambuco'],['PI','Piauí'],['RJ','Rio de Janeiro'],['RN','Rio Grande do Norte'],['RS','Rio Grande do Sul'],['RO','Rondônia'],['RR','Roraima'],['SC','Santa Catarina'],['SP','São Paulo'],['SE','Sergipe'],['TO','Tocantins']].forEach(function(item) { %>
                <option value="<%= item[0] %>"><%= item[0] %> — <%= item[1] %></option>
              <% }); %>
            </select>
          </div>
          <div class="col-md-7">
            <label class="form-label">Cidade</label>
            <select id="editSourceCity" class="form-select" disabled>
              <option value="">Selecione um estado primeiro</option>
            </select>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label">Agendamento</label>
          <select id="editSourceSchedule" class="form-select">
            <option value="manual">Manual</option>
            <option value="hourly">A cada hora</option>
            <option value="daily">Diário</option>
            <option value="weekly">Semanal</option>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Limite de Documentos por Catalogação</label>
          <input type="number" id="editSourceMaxDocuments" class="form-control" min="1" placeholder="Sem limite">
          <small class="text-muted">Número máximo de documentos por execução (vazio = sem limite)</small>
        </div>
        <div class="mb-2 form-check">
          <input type="checkbox" id="editSourceAutoUpdate" class="form-check-input">
          <label class="form-check-label" for="editSourceAutoUpdate">Atualização automática</label>
        </div>
        <div class="mb-2 form-check">
          <input type="checkbox" id="editSourceAutoIndex" class="form-check-input">
          <label class="form-check-label" for="editSourceAutoIndex">Indexar automaticamente após catalogação</label>
        </div>
        <div class="mb-2 form-check">
          <input type="checkbox" id="editSourceIsActive" class="form-check-input">
          <label class="form-check-label" for="editSourceIsActive">Ativo</label>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" onclick="submitEditSource()"><i class="bi bi-check-lg me-1"></i>Salvar</button>
      </div>
    </div>
  </div>
</div>

<!-- ── Export Modal ── -->
<div class="modal fade" id="exportCatalogModal" tabindex="-1">
  <div class="modal-dialog modal-md">
    <div class="modal-content border-0 shadow-lg">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold"><i class="bi bi-download me-2 text-primary"></i>Exportar Catálogo</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body pt-2 pb-4 px-4">
        <p class="text-muted small mb-3">Selecione o que deseja exportar:</p>

        <a href="/admin/catalog/export.csv?mode=sources" class="export-option text-decoration-none">
          <div class="export-icon bg-primary bg-opacity-10 text-primary">
            <i class="bi bi-collection"></i>
          </div>
          <div>
            <div class="export-title">Somente Fontes</div>
            <p class="export-desc">Configurações das fontes de catálogo cadastradas. Ideal para backup ou migração de ambiente.</p>
          </div>
        </a>

        <a href="/admin/catalog/export.csv?mode=documents" class="export-option text-decoration-none">
          <div class="export-icon bg-success bg-opacity-10 text-success">
            <i class="bi bi-file-earmark-text"></i>
          </div>
          <div>
            <div class="export-title">Lista de Documentos</div>
            <p class="export-desc">Todos os documentos catalogados com metadados (tipo, número, datas, URLs). Sem conteúdo extraído.</p>
          </div>
        </a>

        <a href="/admin/catalog/export.csv?mode=full" class="export-option text-decoration-none mb-0">
          <div class="export-icon bg-info bg-opacity-10 text-info">
            <i class="bi bi-file-earmark-richtext"></i>
          </div>
          <div>
            <div class="export-title">Documentos com Conteúdo Extraído</div>
            <p class="export-desc">Inclui o texto completo extraído de cada documento (PDF, DOCX etc.). Arquivo maior, backup total.</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</div>

<!-- ── Import Documents Modal ── -->
<div class="modal fade" id="importDocumentsCsvModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content border-0 shadow-lg">
      <div class="modal-header border-0">
        <h5 class="modal-title fw-bold"><i class="bi bi-file-earmark-arrow-up me-2 text-success"></i>Importar Documentos por CSV</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body px-4">
        <div class="alert alert-info small">
          <i class="bi bi-info-circle me-1"></i>
          Use este import para restaurar documentos exportados com a opção <strong>"Lista de Documentos"</strong> ou <strong>"Documentos com Conteúdo"</strong>.
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Modo de importação</label>
          <div class="list-group">
            <label class="list-group-item d-flex gap-3">
              <input class="form-check-input flex-shrink-0" type="radio" name="documentImportMode" value="merge" checked>
              <span>
                <strong>Mesclar com o catálogo atual</strong>
                <small class="d-block text-muted">Cria documentos novos e atualiza os que já existem pela fonte e pelo ID externo. Não remove nada.</small>
              </span>
            </label>
            <label class="list-group-item d-flex gap-3 border-danger-subtle">
              <input class="form-check-input flex-shrink-0" type="radio" name="documentImportMode" value="replace">
              <span>
                <strong class="text-danger">Substituir tudo pelo CSV</strong>
                <small class="d-block text-muted">Remove fontes, documentos e histórico de execuções do catálogo antes de importar o arquivo.</small>
              </span>
            </label>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Arquivo CSV</label>
          <input type="file" class="form-control" id="documentCsvFile" accept=".csv,text/csv">
        </div>
        <div class="mb-3 form-check">
          <input class="form-check-input" type="checkbox" id="documentIndexAfterImport" checked>
          <label class="form-check-label fw-semibold" for="documentIndexAfterImport">
            Indexar conteúdo importado agora
          </label>
          <small class="d-block text-muted">
            Quando o CSV tiver conteúdo extraído, envia direto para a busca sem baixar o documento no site original.
          </small>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Ou cole o CSV aqui</label>
          <textarea class="form-control font-monospace" id="documentCsvText" rows="8"
            placeholder="id,source_id,source_name,source_slug,source_url,external_id,tipo,numero_ano,descricao,ementa,data_documento,data_publicacao,download_url,detalhe_url,extension,status,metadata_json,extracted_text"></textarea>
        </div>
        <div class="alert alert-secondary small mb-0">
          Coluna obrigatoria: <code>external_id</code>. Para migrar entre maquinas, use arquivos exportados por aqui, pois eles incluem <code>source_slug</code> e <code>source_url</code>.
        </div>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-success" onclick="submitDocumentCsvImport()">
          <i class="bi bi-upload me-1"></i>Importar Documentos
        </button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="importCatalogCsvModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-upload me-2"></i>Importar Fontes de Catalogo por CSV</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Arquivo CSV</label>
          <input type="file" class="form-control" id="catalogCsvFile" accept=".csv,text/csv">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Modo de importação</label>
          <div class="list-group">
            <label class="list-group-item d-flex gap-3">
              <input class="form-check-input flex-shrink-0" type="radio" name="catalogImportMode" value="merge" checked>
              <span>
                <strong>Mesclar com as fontes atuais</strong>
                <small class="d-block text-muted">Cria fontes novas e atualiza fontes existentes por slug ou URL. Não remove documentos.</small>
              </span>
            </label>
            <label class="list-group-item d-flex gap-3 border-danger-subtle">
              <input class="form-check-input flex-shrink-0" type="radio" name="catalogImportMode" value="replace">
              <span>
                <strong class="text-danger">Substituir tudo pelo CSV</strong>
                <small class="d-block text-muted">Remove todo o catálogo atual antes de importar as fontes do arquivo.</small>
              </span>
            </label>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label">Ou cole o CSV</label>
          <textarea class="form-control font-monospace" id="catalogCsvText" rows="10" placeholder="id,name,slug,source_url,state,city,is_active,auto_update_enabled,auto_index_after_catalog,schedule_type,max_documents,config_json"></textarea>
        </div>
        <div class="alert alert-info mb-0 small">
          Colunas aceitas: <code>id,name,slug,source_url,state,city,is_active,auto_update_enabled,auto_index_after_catalog,schedule_type,max_documents,config_json</code>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" onclick="submitCatalogCsvImport()">Importar</button>
      </div>
    </div>
  </div>
</div>

<script>
const catalogImportModal = new bootstrap.Modal(document.getElementById('importCatalogCsvModal'));
const documentImportModal = new bootstrap.Modal(document.getElementById('importDocumentsCsvModal'));

function openDocumentImportModal() {
  document.getElementById('documentCsvFile').value = '';
  document.getElementById('documentCsvText').value = '';
  document.getElementById('documentIndexAfterImport').checked = true;
  document.querySelector('input[name="documentImportMode"][value="merge"]').checked = true;
  documentImportModal.show();
}

document.getElementById('documentCsvFile').addEventListener('change', async (e) => {
  const [file] = e.target.files || [];
  if (!file) return;
  document.getElementById('documentCsvText').value = await file.text();
});

async function submitDocumentCsvImport() {
  const csvText = document.getElementById('documentCsvText').value.trim();
  if (!csvText) {
    alert('Selecione ou cole um CSV antes de importar.');
    return;
  }
  const importMode = document.querySelector('input[name="documentImportMode"]:checked')?.value || 'merge';
  if (importMode === 'replace' && !confirm('Isso vai apagar todas as fontes, documentos e historico do catalogo antes de importar este CSV. Continuar?')) {
    return;
  }
  try {
    const response = await axios.post('/admin/catalog/import-documents', {
      csv_text: csvText,
      import_mode: importMode,
      index_after_import: document.getElementById('documentIndexAfterImport').checked,
    });
    documentImportModal.hide();
    alert(`Importação concluída: ${response.data.total} processados (${response.data.created} criados, ${response.data.updated} atualizados).`);
    location.reload();
  } catch (error) {
    alert('Erro: ' + (error.response?.data?.error || error.message));
  }
}

async function populateCatalogCities() {
  const stateSelect = document.querySelector('#newSourceModal select[name="state"]');
  const citySelect = document.getElementById('catalogSourceCity');
  const state = stateSelect ? stateSelect.value : '';

  citySelect.innerHTML = '<option value="">Carregando cidades...</option>';
  citySelect.disabled = true;

  if (!state) {
    citySelect.innerHTML = '<option value="">Selecione um estado primeiro</option>';
    return;
  }

  try {
    const response = await fetch('/api/cities?state=' + encodeURIComponent(state));
    const cities = await response.json();
    const items = Array.isArray(cities) ? cities : [];

    citySelect.innerHTML = '<option value="">Selecione...</option>';
    items.forEach((city) => {
      const option = document.createElement('option');
      option.value = city;
      option.textContent = city;
      citySelect.appendChild(option);
    });
  } catch (error) {
    citySelect.innerHTML = '<option value="">Nao foi possivel carregar as cidades</option>';
  }

  citySelect.disabled = false;
}

document.querySelector('#newSourceModal select[name="state"]').addEventListener('change', populateCatalogCities);

function openCatalogImportModal() {
  document.getElementById('catalogCsvFile').value = '';
  document.getElementById('catalogCsvText').value = '';
  document.querySelector('input[name="catalogImportMode"][value="merge"]').checked = true;
  catalogImportModal.show();
}

document.getElementById('catalogCsvFile').addEventListener('change', async (e) => {
  const [file] = e.target.files || [];
  if (!file) return;
  document.getElementById('catalogCsvText').value = await file.text();
});

async function submitCatalogCsvImport() {
  const csvText = document.getElementById('catalogCsvText').value.trim();
  if (!csvText) {
    alert('Selecione ou cole um CSV antes de importar.');
    return;
  }

  const importMode = document.querySelector('input[name="catalogImportMode"]:checked')?.value || 'merge';
  if (importMode === 'replace' && !confirm('Isso vai apagar todo o catalogo atual antes de importar este CSV. Continuar?')) {
    return;
  }

  try {
    const response = await axios.post('/admin/catalog/import', {
      csv_text: csvText,
      import_mode: importMode,
    });
    catalogImportModal.hide();
    alert(`Importacao concluida: ${response.data.total} processadas (${response.data.created} criadas, ${response.data.updated} atualizadas).`);
    location.reload();
  } catch (error) {
    alert('Erro: ' + (error.response?.data?.error || error.message));
  }
}

const editSourceModal = new bootstrap.Modal(document.getElementById('editSourceModal'));
const sourceLookup = {
  <% (sources || []).forEach((s, idx) => { %>
  '<%= s.id %>': <%- JSON.stringify({ id: s.id, name: s.name, source_url: s.source_url, state: s.state || '', city: s.city || '', schedule_type: s.schedule_type || 'manual', auto_update_enabled: !!s.auto_update_enabled, auto_index_after_catalog: !!s.auto_index_after_catalog, is_active: !!s.is_active, max_documents: s.max_documents || null }) %><%= idx < (sources || []).length - 1 ? ',' : '' %>
  <% }) %>
};

async function openEditSourceModal(id) {
  const s = sourceLookup[id];
  if (!s) return;
  document.getElementById('editSourceId').value = s.id;
  document.getElementById('editSourceName').value = s.name;
  document.getElementById('editSourceUrl').value = s.source_url;
  document.getElementById('editSourceState').value = s.state || '';
  document.getElementById('editSourceSchedule').value = s.schedule_type || 'manual';
  document.getElementById('editSourceAutoUpdate').checked = !!s.auto_update_enabled;
  document.getElementById('editSourceAutoIndex').checked = !!s.auto_index_after_catalog;
  document.getElementById('editSourceIsActive').checked = !!s.is_active;
  document.getElementById('editSourceMaxDocuments').value = s.max_documents || '';

  if (s.state) {
    await loadEditCatalogCities(s.state, s.city);
  } else {
    document.getElementById('editSourceCity').innerHTML = '<option value="">Selecione um estado primeiro</option>';
    document.getElementById('editSourceCity').disabled = true;
  }

  editSourceModal.show();
}

async function loadEditCatalogCities(state, selectedCity) {
  const citySelect = document.getElementById('editSourceCity');
  citySelect.innerHTML = '<option value="">Carregando...</option>';
  citySelect.disabled = true;
  try {
    const res = await fetch('/api/cities?state=' + encodeURIComponent(state));
    const cities = await res.json();
    citySelect.innerHTML = '<option value="">Nenhuma</option>';
    (Array.isArray(cities) ? cities : []).forEach(c => {
      const opt = document.createElement('option');
      opt.value = c; opt.textContent = c;
      if (c === selectedCity) opt.selected = true;
      citySelect.appendChild(opt);
    });
  } catch (_) {
    citySelect.innerHTML = '<option value="">Erro ao carregar</option>';
  } finally {
    citySelect.disabled = false;
  }
}

document.getElementById('editSourceState').addEventListener('change', function() {
  if (this.value) loadEditCatalogCities(this.value, '');
  else {
    document.getElementById('editSourceCity').innerHTML = '<option value="">Selecione um estado primeiro</option>';
    document.getElementById('editSourceCity').disabled = true;
  }
});

async function submitEditSource() {
  const id = document.getElementById('editSourceId').value;
  const rawMaxDocs = document.getElementById('editSourceMaxDocuments').value;
  const payload = {
    name: document.getElementById('editSourceName').value.trim(),
    source_url: document.getElementById('editSourceUrl').value.trim(),
    state: document.getElementById('editSourceState').value || null,
    city: document.getElementById('editSourceCity').value || null,
    schedule_type: document.getElementById('editSourceSchedule').value,
    auto_update_enabled: String(document.getElementById('editSourceAutoUpdate').checked),
    auto_index_after_catalog: String(document.getElementById('editSourceAutoIndex').checked),
    is_active: String(document.getElementById('editSourceIsActive').checked),
    max_documents: rawMaxDocs ? parseInt(rawMaxDocs, 10) || '' : '',
  };
  try {
    await axios.put('/admin/catalog/' + id, payload);
    editSourceModal.hide();
    location.reload();
  } catch (err) {
    alert('Erro: ' + (err.response?.data?.error || err.message));
  }
}

async function deleteSource(sourceId, docCount, cascade) {
  let message = 'Excluir esta fonte do catalogo?';
  if (docCount > 0 && !cascade) {
    message = 'Esta fonte possui ' + docCount + ' documentos. Use "Excluir Tudo" para remover fonte e documentos juntos.';
    alert(message);
    return;
  }
  
  if (!confirm(cascade 
    ? 'ATENCAO: Isso ira excluir a fonte e TODOS os ' + docCount + ' documentos associados. Esta acao nao pode ser desfeita!' 
    : message)) {
    return;
  }
  
  try {
    const url = '/admin/catalog/' + sourceId + (cascade ? '?cascade=true' : '');
    const response = await fetch(url, { method: 'DELETE' });
    const data = await response.json();
    
    if (response.ok) {
      alert('Fonte excluida com sucesso!');
      location.reload();
    } else {
      alert('Erro: ' + (data.error || 'Falha ao excluir fonte'));
    }
  } catch (error) {
    alert('Erro: ' + error.message);
  }
}
</script>
