<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
  <div>
    <h1 class="h3 mb-2">Usuarios</h1>
    <p class="text-muted mb-0">Gerencie contas, perfis de acesso e status dos usuarios.</p>
  </div>
  <button class="btn btn-primary btn-sm" type="button" onclick="openUserModal()">
    <i class="bi bi-person-plus"></i> Novo usuario
  </button>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card stat-card">
      <div class="card-body"><div class="text-muted small">Total</div><div class="h3 mb-0"><%= stats.total %></div></div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card stat-card">
      <div class="card-body"><div class="text-muted small">Ativos</div><div class="h3 mb-0"><%= stats.active %></div></div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card stat-card">
      <div class="card-body"><div class="text-muted small">Administradores</div><div class="h3 mb-0"><%= stats.admins %></div></div>
    </div>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Nome</th>
          <th>E-mail</th>
          <th>Perfil</th>
          <th>Status</th>
          <th>Ultimo login</th>
          <th class="text-end">Acoes</th>
        </tr>
      </thead>
      <tbody>
        <% data.forEach((user) => { %>
          <tr>
            <td><%= user.name %></td>
            <td><%= user.email %></td>
            <td><span class="badge text-bg-<%= user.role === 'admin' ? 'primary' : 'secondary' %>"><%= user.role === 'admin' ? 'Admin' : 'Usuario' %></span></td>
            <td><span class="badge text-bg-<%= user.status === 'active' ? 'success' : 'warning' %>"><%= user.status === 'active' ? 'Ativo' : 'Inativo' %></span></td>
            <td><%= user.lastLoginAt ? new Date(user.lastLoginAt).toLocaleString('pt-BR') : '-' %></td>
            <td class="text-end">
              <button class="btn btn-sm btn-outline-primary" type="button" onclick='openUserModal(<%- JSON.stringify(user) %>)'>
                <i class="bi bi-pencil"></i>
              </button>
              <button class="btn btn-sm btn-outline-danger" type="button" onclick="deleteUser(<%= user.id %>)">
                <i class="bi bi-trash"></i>
              </button>
            </td>
          </tr>
        <% }) %>
        <% if (data.length === 0) { %>
          <tr><td colspan="6" class="text-center text-muted py-4">Nenhum usuario cadastrado.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<div class="modal fade" id="userModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <form class="modal-content" id="userForm">
      <div class="modal-header">
        <h5 class="modal-title" id="userModalTitle">Usuario</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" name="id">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Nome</label>
            <input class="form-control" name="name" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">E-mail</label>
            <input class="form-control" name="email" type="email" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Senha</label>
            <input class="form-control" name="password" type="password" minlength="6" autocomplete="new-password">
            <div class="form-text">Obrigatoria ao criar. Deixe em branco para manter a senha atual.</div>
          </div>
          <div class="col-md-3">
            <label class="form-label">Perfil</label>
            <select class="form-select" name="role">
              <option value="user">Usuario</option>
              <option value="admin">Admin</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label">Status</label>
            <select class="form-select" name="status">
              <option value="active">Ativo</option>
              <option value="inactive">Inativo</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label">Telefone</label>
            <input class="form-control" name="phone">
          </div>
          <div class="col-md-6">
            <label class="form-label">Regiao</label>
            <input class="form-control" name="region">
          </div>
          <div class="col-12">
            <label class="form-label">Interesses</label>
            <textarea class="form-control" name="interests" rows="3"></textarea>
          </div>
          <div class="col-md-6">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" name="smartSearch" id="smartSearch">
              <label class="form-check-label" for="smartSearch">Busca personalizada</label>
            </div>
          </div>
          <div class="col-md-6">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" name="futureAlerts" id="futureAlerts">
              <label class="form-check-label" for="futureAlerts">Receber alertas futuros</label>
            </div>
          </div>
        </div>
        <div id="userFeedback" class="small text-muted mt-3"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary">Salvar</button>
      </div>
    </form>
  </div>
</div>

<script>
  const userModalEl = document.getElementById('userModal');
  const userModal = new bootstrap.Modal(userModalEl);
  const userForm = document.getElementById('userForm');
  const userFeedback = document.getElementById('userFeedback');

  function openUserModal(user) {
    userForm.reset();
    const fields = userForm.elements;
    userFeedback.textContent = '';
    fields.id.value = user?.id || '';
    fields.name.value = user?.name || '';
    fields.email.value = user?.email || '';
    fields.password.required = !user;
    fields.role.value = user?.role || 'user';
    fields.status.value = user?.status || 'active';
    fields.phone.value = user?.phone || '';
    fields.region.value = user?.region || '';
    fields.interests.value = user?.interests || '';
    fields.smartSearch.checked = user ? Boolean(user.smartSearch) : true;
    fields.futureAlerts.checked = user ? Boolean(user.futureAlerts) : false;
    document.getElementById('userModalTitle').textContent = user ? 'Editar usuario' : 'Novo usuario';
    userModal.show();
  }

  function serializeUserForm() {
    const fields = userForm.elements;
    return {
      name: fields.name.value,
      email: fields.email.value,
      password: fields.password.value,
      role: fields.role.value,
      status: fields.status.value,
      phone: fields.phone.value,
      region: fields.region.value,
      interests: fields.interests.value,
      smartSearch: fields.smartSearch.checked,
      futureAlerts: fields.futureAlerts.checked,
    };
  }

  userForm.addEventListener('submit', async function onSubmit(event) {
    event.preventDefault();
    userFeedback.className = 'small text-muted mt-3';
    userFeedback.textContent = 'Salvando...';
    const id = userForm.elements.id.value;

    try {
      if (id) {
        await axios.put('/admin/users/' + id, serializeUserForm());
      } else {
        await axios.post('/admin/users', serializeUserForm());
      }
      window.location.reload();
    } catch (error) {
      userFeedback.className = 'small text-danger mt-3';
      userFeedback.textContent = error.response?.data?.error || error.message || 'Falha ao salvar usuario.';
    }
  });

  async function deleteUser(id) {
    if (!confirm('Excluir este usuario?')) return;
    try {
      await axios.delete('/admin/users/' + id);
      window.location.reload();
    } catch (error) {
      alert(error.response?.data?.error || error.message || 'Falha ao excluir usuario.');
    }
  }
</script>
