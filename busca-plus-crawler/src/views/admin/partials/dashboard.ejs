<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-4 border-bottom">
  <h1 class="h2"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h1>
  <div class="btn-toolbar mb-2 mb-md-0">
    <button class="btn btn-outline-danger btn-sm me-2" onclick="clearAll()">
      <i class="bi bi-trash me-1"></i> Limpar Tudo
    </button>
    <button class="btn btn-outline-warning btn-sm me-2" onclick="clearIndex()">
      <i class="bi bi-archive me-1"></i> Limpar Índice
    </button>
    <button class="btn btn-outline-secondary btn-sm me-2" onclick="clearDatabase()">
      <i class="bi bi-database-x me-1"></i> Limpar Banco
    </button>
    <button class="btn btn-primary btn-sm" onclick="reindexAll()">
      <i class="bi bi-arrow-repeat me-1"></i> Reindexar
    </button>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card stat-card bg-primary bg-gradient text-white h-100">
      <div class="card-body d-flex align-items-center">
        <div class="icon bg-white text-primary me-3">
          <i class="bi bi-globe"></i>
        </div>
        <div>
          <h3 class="mb-0"><%= stats?.sources?.total || 0 %></h3>
          <small>Fontes Cadastradas</small>
        </div>
      </div>
      <div class="card-footer bg-transparent border-0">
        <small class="text-white-50"><%= stats?.sources?.active || 0 %> ativas</small>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card bg-success bg-gradient text-white h-100">
      <div class="card-body d-flex align-items-center">
        <div class="icon bg-white text-success me-3">
          <i class="bi bi-file-earmark-text"></i>
        </div>
        <div>
          <h3 class="mb-0"><%= stats?.pages?.total || 0 %></h3>
          <small>Páginas Coletadas</small>
        </div>
      </div>
      <div class="card-footer bg-transparent border-0">
        <small class="text-white-50"><%= stats?.pages?.indexed || 0 %> indexadas</small>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card bg-info bg-gradient text-white h-100">
      <div class="card-body d-flex align-items-center">
        <div class="icon bg-white text-info me-3">
          <i class="bi bi-clock"></i>
        </div>
        <div>
          <h3 class="mb-0"><%= stats?.pages?.recent24h || 0 %></h3>
          <small>Coletadas (24h)</small>
        </div>
      </div>
      <div class="card-footer bg-transparent border-0">
        <small class="text-white-50">&nbsp;</small>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card <%= (stats?.pages?.errors || 0) > 0 ? 'bg-danger' : 'bg-secondary' %> bg-gradient text-white h-100">
      <div class="card-body d-flex align-items-center">
        <div class="icon bg-white <%= (stats?.pages?.errors || 0) > 0 ? 'text-danger' : 'text-secondary' %> me-3">
          <i class="bi bi-exclamation-triangle"></i>
        </div>
        <div>
          <h3 class="mb-0"><%= stats?.pages?.errors || 0 %></h3>
          <small>Erros</small>
        </div>
      </div>
      <div class="card-footer bg-transparent border-0">
        <small class="text-white-50">&nbsp;</small>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Jobs Recentes</h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Fonte</th>
                <th>Tipo</th>
                <th>Status</th>
                <th>Data</th>
              </tr>
            </thead>
            <tbody>
              <% if (stats?.recentJobs?.length > 0) { %>
                <% stats.recentJobs.forEach(job => { %>
                  <tr>
                    <td><%= job.source?.name || '-' %></td>
                    <td><span class="badge bg-secondary"><%= job.type %></span></td>
                    <td>
                      <span class="badge <%= job.status === 'completed' ? 'bg-success' : job.status === 'failed' ? 'bg-danger' : 'bg-warning' %>">
                        <%= job.status %>
                      </span>
                    </td>
                    <td><small><%= new Date(job.created_at).toLocaleString('pt-BR') %></small></td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="4" class="text-center text-muted py-4">Nenhum job encontrado</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
      <div class="card-footer text-center">
        <a href="/admin/jobs" class="text-decoration-none">Ver todos os jobs</a>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-activity me-2"></i>Índice de Busca</h5>
      </div>
      <div class="card-body">
        <div class="row text-center">
          <div class="col-6">
            <h4 class="mb-0"><%= stats?.indexStats?.documentCount || 0 %></h4>
            <small class="text-muted">Documentos</small>
          </div>
          <div class="col-6">
            <h4 class="mb-0"><%= stats?.pages?.indexed || 0 %></h4>
            <small class="text-muted">Indexados</small>
          </div>
        </div>
        <hr>
        <div class="d-flex justify-content-between align-items-center">
          <small class="text-muted">Status do Índice</small>
          <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Ativo</span>
        </div>
      </div>
      <div class="card-footer text-center">
        <a href="/admin/pages" class="text-decoration-none">Ver todas as páginas</a>
      </div>
    </div>
  </div>
</div>

<script>
  async function reindexAll() {
    if (!confirm('Reindexar todas as páginas?')) return;
    try {
      const btn = event.target.closest('button');
      btn.disabled = true;
      btn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i> Indexando...';
      const response = await axios.post('/api/admin/reindex-all');
      alert('Reindexação iniciada: ' + response.data.message);
      location.reload();
    } catch (error) {
      alert('Erro: ' + (error.response?.data?.error || error.message));
      location.reload();
    }
  }

  async function clearIndex() {
    if (!confirm('Limpar apenas o índice do Typesense?\nAs páginas no banco serão mantidas.')) return;
    try {
      const response = await axios.post('/api/admin/clear-index');
      alert(response.data.message);
      location.reload();
    } catch (error) {
      alert('Erro: ' + (error.response?.data?.error || error.message));
    }
  }

  async function clearDatabase() {
    if (!confirm('Limpar apenas o banco de dados?\nO índice do Typesense será mantido.\n\nATENÇÃO: Isso removerá TODAS as páginas e jobs!')) return;
    try {
      const response = await axios.post('/api/admin/clear-database');
      alert('Banco limpo: ' + response.data.deletedPages + ' páginas, ' + response.data.deletedJobs + ' jobs removidos');
      location.reload();
    } catch (error) {
      alert('Erro: ' + (error.response?.data?.error || error.message));
    }
  }

  async function clearAll() {
    if (!confirm('⚠️ ATENÇÃO: Isso irá remover:\n\n- Todas as páginas do banco\n- Todos os jobs\n- Todos os logs\n- Todo o índice do Typesense\n\nEsta ação NÃO pode ser desfeita!\n\nContinuar?')) return;
    if (!confirm('Tem certeza absoluta? Digite OK para confirmar.')) return;
    try {
      const response = await axios.post('/api/admin/clear-all');
      alert('✅ ' + response.data.message);
      location.reload();
    } catch (error) {
      alert('Erro: ' + (error.response?.data?.error || error.message));
    }
  }
</script>
