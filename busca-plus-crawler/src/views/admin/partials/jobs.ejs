<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-4 border-bottom">
  <h1 class="h2"><i class="bi bi-clock-history me-2"></i>Jobs de Coleta</h1>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>ID</th>
            <th>Fonte</th>
            <th>Tipo</th>
            <th>Status</th>
            <th>Páginas Processadas</th>
            <th>Erro</th>
            <th>Iniciado</th>
            <th>Finalizado</th>
          </tr>
        </thead>
        <tbody>
          <% if (data?.data?.length > 0) { %>
            <% data.data.forEach(job => { %>
              <tr>
                <td><small>#<%= job.id %></small></td>
                <td><span class="badge bg-light text-dark"><%= job.source?.name || '-' %></span></td>
                <td><span class="badge bg-secondary"><%= job.type %></span></td>
                <td>
                  <span class="badge <%= job.status === 'completed' ? 'bg-success' : job.status === 'failed' ? 'bg-danger' : job.status === 'active' ? 'bg-primary' : 'bg-warning' %>">
                    <%= job.status %>
                  </span>
                </td>
                <td><%= job.processed_pages || 0 %> / <%= job.total_pages || 0 %></td>
                <td><small><%= job.error_message ? job.error_message.substring(0, 30) : '-' %></small></td>
                <td><small><%= new Date(job.created_at).toLocaleString('pt-BR') %></small></td>
                <td><small><%= job.completed_at ? new Date(job.completed_at).toLocaleString('pt-BR') : '-' %></small></td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="8" class="text-center text-muted py-4">Nenhum job encontrado</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <% if (data?.pages > 1) { %>
    <div class="card-footer">
      <nav>
        <ul class="pagination justify-content-center mb-0">
          <% for (let i = 1; i <= data.pages; i++) { %>
            <li class="page-item <%= data.page === i ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %>"><%= i %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    </div>
  <% } %>
</div>
