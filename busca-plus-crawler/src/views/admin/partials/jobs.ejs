<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-4 border-bottom">
  <h1 class="h4 mb-0 fw-bold"><i class="bi bi-clock-history me-2 text-primary"></i>Jobs de Coleta</h1>
  <div class="d-flex gap-2 flex-wrap">
    <% const statusParam = pagination?.status || ''; %>
    <a href="/admin/jobs" class="btn btn-sm <%= !statusParam ? 'btn-primary' : 'btn-outline-secondary' %>">Todos</a>
    <a href="/admin/jobs?status=running" class="btn btn-sm <%= statusParam === 'running' ? 'btn-primary' : 'btn-outline-secondary' %>"><i class="bi bi-play-circle me-1"></i>Ativos</a>
    <a href="/admin/jobs?status=pending" class="btn btn-sm <%= statusParam === 'pending' ? 'btn-warning' : 'btn-outline-secondary' %>"><i class="bi bi-hourglass me-1"></i>Pendentes</a>
    <a href="/admin/jobs?status=failed" class="btn btn-sm <%= statusParam === 'failed' ? 'btn-danger' : 'btn-outline-secondary' %>"><i class="bi bi-x-circle me-1"></i>Falhas</a>
    <button class="btn btn-sm btn-outline-danger" onclick="cleanCompletedJobs()">
      <i class="bi bi-trash me-1"></i>Limpar Concluídos
    </button>
  </div>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>ID</th>
            <th>Fonte</th>
            <th>Tipo</th>
            <th>Status</th>
            <th>Progresso</th>
            <th>Iniciado</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (data?.data?.length > 0) { %>
            <% data.data.forEach(job => { %>
              <tr id="job-<%= job.id %>">
                <td><small class="text-muted">#<%= job.id %></small></td>
                <td>
                  <span class="fw-semibold"><%= job.source?.name || '—' %></span>
                </td>
                <td>
                  <span class="badge bg-secondary-subtle text-secondary border"><%= job.type %></span>
                </td>
                <td>
                  <span class="badge rounded-pill <%=
                    job.status === 'completed' ? 'bg-success' :
                    job.status === 'failed'    ? 'bg-danger'  :
                    job.status === 'running'   ? 'bg-primary' :
                    job.status === 'pending'   ? 'bg-warning text-dark' : 'bg-secondary'
                  %>">
                    <%= job.status === 'completed' ? 'Concluído' :
                        job.status === 'failed'    ? 'Falha' :
                        job.status === 'running'   ? 'Executando' :
                        job.status === 'pending'   ? 'Pendente' :
                        job.status === 'cancelled' ? 'Cancelado' : job.status %>
                  </span>
                </td>
                <td>
                  <% const found = Number(job.pages_found || 0); %>
                  <% const crawled = Number(job.pages_crawled || 0); %>
                  <% const pct = found > 0 ? Math.round((crawled / found) * 100) : 0; %>
                  <div class="d-flex align-items-center gap-2">
                    <div class="progress flex-grow-1" style="height:6px;min-width:70px;">
                      <div class="progress-bar <%= job.status === 'failed' ? 'bg-danger' : job.status === 'completed' ? 'bg-success' : 'bg-primary' %>"
                        role="progressbar" style="width:<%= pct %>%"></div>
                    </div>
                    <small class="text-muted text-nowrap"><%= crawled %>/<%= found %></small>
                  </div>
                  <% if (job.pages_errored > 0) { %>
                    <small class="text-danger d-block"><i class="bi bi-exclamation-triangle me-1"></i><%= job.pages_errored %> erros</small>
                  <% } %>
                </td>
                <td>
                  <small class="text-muted"><%= new Date(job.created_at).toLocaleString('pt-BR') %></small>
                  <% if (job.finished_at) { %>
                    <small class="text-muted d-block">até <%= new Date(job.finished_at).toLocaleString('pt-BR') %></small>
                  <% } %>
                </td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <% if (job.status === 'pending' || job.status === 'running') { %>
                      <button class="btn btn-outline-warning" onclick="cancelJob('<%= job.id %>')" title="Cancelar">
                        <i class="bi bi-x-circle"></i>
                      </button>
                    <% } %>
                    <% if (['completed','failed','cancelled'].includes(job.status)) { %>
                      <button class="btn btn-outline-danger" onclick="deleteJob('<%= job.id %>')" title="Excluir">
                        <i class="bi bi-trash"></i>
                      </button>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="7" class="text-center text-muted py-5">
                <i class="bi bi-clock-history fs-1 d-block mb-2 opacity-25"></i>
                Nenhum job encontrado
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <% if (data?.pages > 1) { %>
    <div class="card-footer bg-white">
      <nav>
        <ul class="pagination pagination-sm justify-content-center mb-0">
          <% for (let i = 1; i <= data.pages; i++) { %>
            <li class="page-item <%= data.page === i ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %><%= pagination?.status ? '&status=' + pagination.status : '' %>"><%= i %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    </div>
  <% } %>
</div>

<script>
  async function cancelJob(jobId) {
    if (!confirm('Deseja cancelar este job?')) return;
    try {
      await axios.post('/api/jobs/' + jobId + '/cancel');
      location.reload();
    } catch (error) {
      alert('Erro: ' + (error.response?.data?.error || error.message));
    }
  }

  async function deleteJob(jobId) {
    if (!confirm('Deseja excluir este job?')) return;
    try {
      await axios.delete('/api/jobs/' + jobId);
      document.getElementById('job-' + jobId).remove();
    } catch (error) {
      alert('Erro: ' + (error.response?.data?.error || error.message));
    }
  }

  async function cleanCompletedJobs() {
    if (!confirm('Deseja limpar todos os jobs concluídos (com sucesso ou falha)?')) return;
    try {
      const response = await axios.post('/api/jobs/clean-completed');
      alert(response.data.deleted + ' jobs removidos');
      location.reload();
    } catch (error) {
      alert('Erro: ' + (error.response?.data?.error || error.message));
    }
  }
</script>
